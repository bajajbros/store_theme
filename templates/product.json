        "custom_liquid_CNkd9J": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% comment %}\n  STEP 1: Yeh poora code apne Custom Liquid block mein paste karo\n  (purana size-chart code replace kar do isse)\n{% endcomment %}\n\n<style>\n  /* Size label row ko flex banao taaki button same line pe aaye */\n  .product-form__label,\n  .variant-label,\n  label[for*=\"size\"],\n  label[for*=\"Size\"],\n  .product-option--label,\n  .product-variant--label {\n    display: flex !important;\n    align-items: center !important;\n    justify-content: space-between !important;\n    width: 100% !important;\n  }\n\n  .size-chart-btn {\n    display: inline-flex;\n    align-items: center;\n    gap: 5px;\n    background: none;\n    border: none;\n    cursor: pointer;\n    font-size: 12px;\n    font-weight: 500;\n    color: #555;\n    text-decoration: underline;\n    text-underline-offset: 3px;\n    padding: 0;\n    margin-left: auto;\n    transition: color 0.2s;\n    white-space: nowrap;\n    line-height: 1;\n  }\n  .size-chart-btn:hover { color: #000; }\n\n  /* Overlay */\n  .size-chart-overlay {\n    display: none;\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,0.5);\n    z-index: 9998;\n  }\n  .size-chart-overlay.active { display: block; }\n\n  /* Modal */\n  .size-chart-modal {\n    display: none;\n    position: fixed;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    background: #fff;\n    border-radius: 12px;\n    padding: 28px 24px 24px;\n    z-index: 9999;\n    width: min(600px, 92vw);\n    max-height: 85vh;\n    overflow-y: auto;\n    box-shadow: 0 20px 60px rgba(0,0,0,0.2);\n  }\n  .size-chart-modal.active {\n    display: block;\n    animation: scIn 0.25s ease;\n  }\n  @keyframes scIn {\n    from { opacity: 0; transform: translate(-50%, -48%) scale(0.95); }\n    to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }\n  }\n\n  .size-chart-modal__header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 20px;\n  }\n  .size-chart-modal__title {\n    font-size: 17px;\n    font-weight: 700;\n    margin: 0;\n  }\n  .size-chart-modal__subtitle {\n    font-size: 12px;\n    color: #888;\n    margin-top: 2px;\n  }\n  .size-chart-modal__close {\n    background: #f3f3f3;\n    border: none;\n    border-radius: 50%;\n    width: 32px;\n    height: 32px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    transition: background 0.2s;\n  }\n  .size-chart-modal__close:hover { background: #e0e0e0; }\n\n  .size-chart-table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 14px;\n  }\n  .size-chart-table th,\n  .size-chart-table td {\n    padding: 11px 10px;\n    text-align: center;\n    border: 1px solid #e5e5e5;\n  }\n  .size-chart-table thead th {\n    background: #111;\n    color: #fff;\n    font-weight: 600;\n    font-size: 13px;\n    letter-spacing: 0.05em;\n  }\n  .size-chart-table tbody tr:nth-child(even) td { background: #f9f9f9; }\n  .size-chart-table tbody td:first-child {\n    font-weight: 600;\n    text-align: left;\n    padding-left: 14px;\n    background: #f3f3f3;\n  }\n\n  .size-chart-note {\n    margin-top: 14px;\n    font-size: 12px;\n    color: #888;\n    text-align: center;\n  }\n</style>\n\n{% comment %} Button ko JS se size label ke andar inject karta hai {% endcomment %}\n<script>\n  document.addEventListener('DOMContentLoaded', function () {\n    // Yeh selector alag alag themes mein alag hota hai - sab try karta hai\n    const selectors = [\n      '.product-form__label',\n      'label[for*=\"size\"]',\n      'label[for*=\"Size\"]',\n      '.variant-label',\n      '.product-option--label',\n      '.product-variant--label',\n      '.product-form .form__label',\n      '.product-option__label',\n      'fieldset legend',\n    ];\n\n    let sizeLabel = null;\n\n    for (const sel of selectors) {\n      const allLabels = document.querySelectorAll(sel);\n      for (const el of allLabels) {\n        if (/size/i.test(el.textContent)) {\n          sizeLabel = el;\n          break;\n        }\n      }\n      if (sizeLabel) break;\n    }\n\n    if (sizeLabel) {\n      // Label ko flex banao\n      sizeLabel.style.display = 'flex';\n      sizeLabel.style.alignItems = 'center';\n      sizeLabel.style.justifyContent = 'space-between';\n      sizeLabel.style.width = '100%';\n\n      // Button inject karo\n      const btn = document.createElement('button');\n      btn.type = 'button';\n      btn.className = 'size-chart-btn';\n      btn.setAttribute('aria-haspopup', 'dialog');\n      btn.innerHTML = `\n        <svg width=\"13\" height=\"13\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M3 7h2l2 4 2-4h2l2 4 2-4h2\"/><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/>\n        </svg>\n        Size Chart\n      `;\n      btn.addEventListener('click', function () {\n        document.getElementById('sizeChartModal').classList.add('active');\n        document.getElementById('sizeChartOverlay').classList.add('active');\n      });\n\n      sizeLabel.appendChild(btn);\n    } else {\n      console.warn('[SizeChart] Size label not found. Check selector.');\n    }\n  });\n</script>\n\n<!-- Overlay -->\n<div id=\"sizeChartOverlay\" class=\"size-chart-overlay\"\n  onclick=\"document.getElementById('sizeChartModal').classList.remove('active'); this.classList.remove('active');\"></div>\n\n<!-- Modal -->\n<div id=\"sizeChartModal\" class=\"size-chart-modal\" role=\"dialog\" aria-modal=\"true\">\n  <div class=\"size-chart-modal__header\">\n    <div>\n      <p class=\"size-chart-modal__title\">Size Chart – Drop-shoulder</p>\n      <p class=\"size-chart-modal__subtitle\">180gsm &bull; 210gsm &bull; 240gsm &bull; AcidWash OS</p>\n    </div>\n    <button class=\"size-chart-modal__close\" type=\"button\" aria-label=\"Close\"\n      onclick=\"document.getElementById('sizeChartModal').classList.remove('active'); document.getElementById('sizeChartOverlay').classList.remove('active');\">\n      <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\">\n        <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/>\n      </svg>\n    </button>\n  </div>\n\n  <table class=\"size-chart-table\">\n    <thead>\n      <tr>\n        <th></th><th>S</th><th>M</th><th>L</th><th>XL</th><th>XXL</th>\n      </tr>\n    </thead>\n    <tbody>\n      <tr><td>Chest</td><td>42</td><td>44</td><td>46</td><td>48</td><td>50</td></tr>\n      <tr><td>Length</td><td>27.5</td><td>28</td><td>28.5</td><td>29</td><td>29.5</td></tr>\n      <tr><td>Shoulder</td><td>20</td><td>21</td><td>22</td><td>23</td><td>24</td></tr>\n      <tr><td>Sleeve Length</td><td>8.5</td><td>9</td><td>9.5</td><td>10</td><td>10.5</td></tr>\n    </tbody>\n  </table>\n\n  <p class=\"size-chart-note\">All measurements in inches &bull; Tolerance ± 1 inch</p>\n</div>"
          }
