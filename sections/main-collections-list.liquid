{{ 'collection-list.css' | asset_url | stylesheet_tag }}
{%- liquid
  case section.settings.sort
    when 'products_high', 'products_low'
      assign collections = collections | sort: 'all_products_count'
    when 'date', 'date_reversed'
      assign collections = collections | sort: 'published_at'
  endcase

  if section.settings.sort == 'products_high' or section.settings.sort == 'date_reversed' or section.settings.sort == 'alphabetical_reversed'
    assign collections = collections | reverse
  endif
-%}

<div class="collection-list-section section-gap color-{{ section.settings.color_scheme }}">
  <div class="page--width">
    {% if section.settings.heading != blank %}
      <heading-main class="main-heading text-align-{{ section.settings.content_alignment }}">
        {% if section.settings.heading != blank %}
          <{{ section.settings.heading_seo }} class="section-title {{ section.settings.heading_size }}">
            {{- section.settings.heading -}}
          </{{ section.settings.heading_seo }}>
        {% endif %}
      </heading-main>
    {% endif %}
    {% assign paginate_by = section.settings.collections_per_page %}
    {%- paginate collections by paginate_by -%}
      <div class="collection-list--grid flex wrap text-align-{{ section.settings.text_alignment }}">
        {% for collection in collections offset: paginate.current_offset limit: paginate_by %}
          {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
          {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
          {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
          {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
          {% render 'collection-card',
            collection_card: collection,
            section: section,
            image_ratio: section.settings.image_ratio,
            placeholder_image: placeholder_image
          %}
        {% endfor %}
      </div>

      {% liquid
        if paginate.pages > 1
          echo '   <div class="pagination-wrapper"><nav class="pagination" role="navigation" aria-label="Pagination">'
          render 'pagination', paginate: paginate
          echo '</nav></div>'
        endif
      %}
    {% endpaginate %}
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;
    --grid-gap:{{ section.settings.column_gap }}px;
  }

  @media screen and (min-width: 992px) {
    #shopify-section-{{ section.id }} {
      --collection-per-row: {{ section.settings.number_item }};
    }
  }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
      --grid-gap:{{ section.settings.column_gap_mobile }}px;
      --grid-item-per-row:{{ section.settings.mobile_item_per_row }};
    }

  }
</style>
