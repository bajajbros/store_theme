{{ 'collapsible-content.css' | asset_url | stylesheet_tag }}
<div class="block accordion-section section-gap color-{{ section.settings.color_scheme }}">
  <div class="page--width">
    <div class="accordion-wrapper {% if section.settings.content_position =="left" %}accordion-tab-column{% endif %}">
      <div class="accordion-header">
        {% if section.settings.heading != blank or section.settings.description != blank %}
          <heading-main class="main-heading">
            {% if section.settings.heading != blank %}
              <{{ section.settings.heading_seo }} class="section-title body-font {{ section.settings.heading_size }}">
                {% if section.settings.heading != blank -%}
                  {{- section.settings.heading -}}
                {% endif %}
              </{{ section.settings.heading_seo }}>
            {% endif %}
            {% if section.settings.description != blank %}
              <div class="section-description {{ section.settings.description_size }}">
                {{ section.settings.description | newline_to_br }}
              </div>
            {% endif %}
          </heading-main>
        {% endif %}
        {% if section.settings.image != blank %}
          <div class="accordion-image">
            <img
              srcset="
                {%- if section.settings.image.width >= 165 -%}{{ section.settings.image | image_url: width: 165 }} 165w,{%- endif -%}
                {%- if section.settings.image.width >= 330 -%}{{ section.settings.image | image_url: width: 330 }} 330w,{%- endif -%}
                {%- if section.settings.image.width >= 535 -%}{{ section.settings.image | image_url: width: 535 }} 535w,{%- endif -%}
                {{ section.settings.image | image_url }} {{ section.settings.image.width }}w
              "
              src="{{ section.settings.image | image_url: width: 535 }}"
              sizes="(min-width: 750px) calc(100vw - 10rem),calc(100vw - 3rem)"
              alt="{{ section.settings.image.alt | escape }}"
              height="{{ section.settings.image.height }}"
              width="{{ section.settings.image.width }}"
              loading="lazy"
            >
          </div>
        {% endif %}
      </div>
      {% if section.blocks.size > 0 %}
        <custom-accordion-des class="accordion-content block">
          {% for block in section.blocks %}
            {% if block.settings.heading != blank %}
              <div class="accordion-item">
                <details
                  class="accordion-details"
                  {% if section.settings.open_first and forloop.first %}
                    open
                  {% endif %}
                >
                  <summary class="accordion-details-summary flex align-items-start justify-content-between">
                    {% comment %} <span class="accordion-number heading-font">0{{ forloop.index }}</span> {% endcomment %}
                    <h6 class="accordion-details-title">{{ block.settings.heading -}}</h6>
                    <svg xmlns="http://www.w3.org/2000/svg" class="accordion-toggle" viewBox="0 0 20 20" fill="none">
                      <path class="horizontal-line" d="M3.125 10H16.875" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                      <path class="vertical-line" d="M10 3.125L10 16.875" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </summary>
                  <div class="accordion-details-content rte">
                    {{ block.settings.description }}
                  </div>
                </details>
              </div>
            {% endif %}
          {% endfor %}
        </custom-accordion-des>
      {% endif %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;
  }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
    }

  }
</style>
{% schema %}
{
  "name": "t:sections.collapsible-content.name",
   "class": "section-collapsible-content",
  "tag": "section",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
     {
      "type": "color_scheme",
      "id":"color_scheme",
      "label": "t:global.color_scheme.label", 
      "default":"scheme-1"
    },
    {
      "type":"inline_richtext",
      "id":"heading",
         "label": "t:global.general_label.heading.label",
      "default":"Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "default": "h3",
      
 "label": "t:global.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:global.heading_size.options.h1.label"
        },
        {
          "value": "h2",
         "label": "t:global.heading_size.options.h2.label"
        },
        {
          "value": "h3",
         "label": "t:global.heading_size.options.h3.label"
        },
        {
          "value": "h4",
        "label": "t:global.heading_size.options.h4.label"
        },
        {
          "value": "h5",
          "label": "t:global.heading_size.options.h5.label"
        },
        {
          "value": "h6",
        "label": "t:global.heading_size.options.h6.label"
        }
      ]

    },
    {
      "type": "select",
      "id": "heading_seo",
      "default": "h3",
      
      "label": "t:global.heading_seo.label",
      "info": "t:global.heading_seo.info",
      "options": [
         {
            "value": "h1",
            "label": "t:global.heading_seo.options.h1.label"
          },
          {
            "value": "h2",
           "label": "t:global.heading_seo.options.h2.label"
          },
          {
            "value": "h3",
           "label": "t:global.heading_seo.options.h3.label"
          },
          {
            "value": "h4",
          "label": "t:global.heading_seo.options.h4.label"
          },
          {
            "value": "h5",
            "label": "t:global.heading_seo.options.h5.label"
          },
          {
            "value": "h6",
          "label": "t:global.heading_seo.options.h6.label"
          }
        ]
    },
    {
      "type": "textarea",
      "id": "description",
         "label": "t:global.general_label.description.label",
      "default":"Tell your brand's story through images"
    },
     {
      "type": "select",
      "id": "description_size",
      "default": "text-lg",
       "label": "t:global.description_size.label",
      "options": [
        {
          "value": "text-xl",
          "label": "t:global.description_size.options.x-large.label"
        },
        {
          "value": "text-lg",
          "label": "t:global.description_size.options.large.label"
        },
        {
          "value": "text-base",
          "label": "t:global.description_size.options.medium.label"
        },
        {
          "value": "text-sm",
          "label": "t:global.description_size.options.small.label"
        },
        {
          "value": "text-xs",
          "label": "t:global.description_size.options.x-small.label"

        }
      ]
  },
    {
          "type": "image_picker",
          "id": "image",
          "label": "t:global.general_label.image.label"
        },
    {
      "type":"checkbox",
      "id":"open_first",
      "label":"t:sections.collapsible-content.settings.open_first.label",
      "default":true
    },
  {
    "type": "select",
    "id":"content_position",
    "label":"t:sections.collapsible-content.settings.content_position.label",
    "options": [
      {
      "label":"t:sections.collapsible-content.settings.content_position.options.top.label",
        "value": "top"
      },
      {
        "label":"t:sections.collapsible-content.settings.content_position.options.left.label",
        "value": "left"
      }
    ]
  },
    {
    "type": "header",
      "content": "Section space"
    },
    {
    "type": "range",
    "id": "top_space_desktop",
    "label": "t:global.section_spacing.top_space_desktop.label",
    "default": 70,
    "min": 0,
    "max": 150,
    "step": 5
  },
  {
    "type": "range",
    "id": "bottom_space_desktop",
    "label": "t:global.section_spacing.bottom_space_desktop.label",
    "default": 70,
    "min": 0,
    "max": 150,
    "step": 5
  },
  {
    "type": "range",
    "id": "top_space_mobile",
    "label": "t:global.section_spacing.top_space_mobile.label",
    "default": 40,
    "min": 0,
    "max": 100,
    "step": 5
  },
  {
    "type": "range",
    "id": "bottom_space_mobile",
    "label": "t:global.section_spacing.bottom_space_mobile.label",
    "default": 40,
    "min": 0,
    "max": 100,
    "step": 5
  }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "t:sections.collapsible-content.blocks.content.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
         "label": "t:global.general_label.heading.label",
          "default":"Heading here"
        },
        {
          "type": "richtext",
          "id": "description",
           "label": "t:global.general_label.description.label",
          "default":"<p>Description here</p>"
        }

      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible-content.presets.name",
      "blocks": [
          {
          "type": "content"
        },
        {
          "type": "content"
        },
        {
          "type": "content"
        },
        {
          "type": "content"
        },
        {
          "type": "content"
        }
      ]
    }
  ]
}
{% endschema %}
