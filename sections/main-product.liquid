{{ 'product.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'product.css' | asset_url | stylesheet_tag }}
{{ 'photoswipe.css' | asset_url | stylesheet_tag }}

{% assign current_variant = product.selected_or_first_available_variant %}

{%- assign unique_3d_model = product.media | where: 'media_type', 'model' | first -%}
{%- if unique_3d_model -%}
  <link rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css">
{%- endif -%}
<main-product class="block section-gap color-{{ section.settings.color_scheme }}" data-product-info>
  <product-recently-viewed data-product-id="{{ product.id }}" class="hidden"></product-recently-viewed>
  <div class="{% if section.settings.product_template_type  == 'template1' %}main-product-wrapper{% else %} {% if section.settings.section_layout != 'full' %}page--width{% else %}page--container{% endif %}{% endif %}">
    {% if section.settings.product_template_type == 'template1' %}
      {% render 'product-template-first', product: product, section: section, current_variant: current_variant %}
    {% else %}
      <div class="featured-product--grid main-product--grid slider-left">
        {% render 'product-template-second',
          template: section.settings.product_template_type,
          product: product,
          section: section,
          zoomImage: true,
          current_variant: current_variant
        %}
      </div>
    {% endif %}
  </div>
  <script type="application/json" data-name="main-product-section">
    {{ product.variants | json }}
  </script>
  <script type="application/json" data-name="product-options">
    [{%- for option in product.options_with_values -%}{"name": "{{ option.name }}","position": {{ forloop.index }},"values": [{%- for value in option.values -%}"{{ value }}"{% unless forloop.last %}, {% endunless %}{%- endfor -%}] }{% unless forloop.last %}, {% endunless %} {%- endfor -%} ]
  </script>
  <script type="application/json" data-name="product-inventories">
    [{% for variant in product.variants %}
        {
          "id": {{ variant.id }},
          "inventory_management": "{{ variant.inventory_management }}",
          "inventory_policy": "{{ variant.inventory_policy }}",
          "inventory_quantity": "{{ variant.inventory_quantity }}"
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}]
  </script>
</main-product>
{% if section.settings.enable_stickyProduct %}
  {% render 'sticky-product', product: product, section: section, current_variant: current_variant %}
{% endif %}
<script type="application/json" id="ProductJSON-{{ product.id }}">
  {{ product.media | where: 'media_type', 'model' | json }}
</script>
{%- if unique_3d_model -%}
  <script src="{{ 'product-model.js' | asset_url }}" defer></script>
{% endif %}
<script type="module">
    import PhotoSwipeLightbox from '{{ 'photoswipe-lightbox.js' | asset_url }}';
    const lightbox = new PhotoSwipeLightbox({
      gallery: '.product-media-popup-images',
      children: 'a',
      showHideAnimationType: 'zoom',
      bgOpacity: 1,
      pswpModule: () => import('{{ 'photoswipe.js' | asset_url }}')
    });
    lightbox.on('change', () => {
       document.querySelectorAll("iframe[src*='player.vimeo.com']").forEach((video) => {
              if(video.getAttribute('data-autoplay') == 'true' || video.hasAttribute('autoplay')) return false;
                video.contentWindow.postMessage('{"method":"pause"}', "*");
        });
      document.querySelectorAll(".youtube-video,iframe[src*='www.youtube.com']").forEach((video) => {
                  if(video.getAttribute('data-autoplay') == 'true' || video.hasAttribute('autoplay')) return false;
                  video.contentWindow.postMessage('{"event":"command","func":"' + "pauseVideo" + '","args":""}',"*");
          });
        document.querySelectorAll("video").forEach((video) => {
            if(video.getAttribute('data-autoplay') == 'true' || video.hasAttribute('autoplay')) return false;
            video.pause();
        });
  });
    lightbox.init();
</script>

<script type="application/ld+json">
  {{ product | structured_data }}
</script>


<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;

  }



  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
    }

  }
</style>

