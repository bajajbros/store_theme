{{ 'richtext.css' | asset_url | stylesheet_tag }}
<div class="rich-text-section section-gap color-{{ section.settings.color_scheme }}">
  <div class="page--width">
    <div class="rich-text media-width--{{ section.settings.content_width }} text-align-{{ section.settings.content_alignment }} {% if section.settings.option_style == "collage" %}rich-text-with-collage{% endif %}">
      {% if section.settings.option_style == 'none' %}
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'heading' %}
              {%- if block.settings.heading != blank -%}
                <div class="rich-text-heading--wrapper">
                  <{{ block.settings.heading_seo }} class="rich-text--heading {{  block.settings.heading_size }}">
                    {{- block.settings.heading -}}
                  </{{ block.settings.heading_seo }}>
                </div>
              {% endif %}
            {% when 'description' %}
              {%- if block.settings.description != blank -%}
                <div class="description rich-text--text {{ block.settings.description_size }}">
                  {{ block.settings.description | replace: '<p></p>', '<br>' }}
                </div>
              {% endif %}
            {% when 'button' %}
              {%- if block.settings.btn_text != blank and block.settings.btn_link != blank -%}
                <div class="rich-text--button">
                  <a
                    href="{{ block.settings.btn_link }}"
                    class="{% if block.settings.button_style == 'text' %}underline--link{% else %} {{ settings.button_font }}-font button button-{{ block.settings.button_style }} button-{{ block.settings.btn_size }} hover-{{ block.settings.hover_effect }}{% endif %}"
                  >
                    <span class="button-text">{{ block.settings.btn_text }}</span>
                    {% if block.settings.button_style == 'text' %}
                      <span class="link-arrow">
                        <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentColor"/>
                        </svg>
                      </span>
                    {% endif %}
                  </a>
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
      {% else %}
        <div class="rich-text-collage--wrapper">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'heading' %}
                {%- if block.settings.heading != blank -%}
                  <div class="rich-text-heading--wrapper">
                    <{{ block.settings.heading_seo }} class="rich-text--heading {{  block.settings.heading_size }}">
                      {{- block.settings.heading -}}
                    </{{ block.settings.heading_seo }}>
                  </div>
                {% endif %}
              {% when 'button' %}
                {%- if block.settings.btn_text != blank and block.settings.btn_link != blank -%}
                  <div class="rich-text--button">
                    <a
                      href="{{ block.settings.btn_link }}"
                      class="{% if block.settings.button_style == 'text' %}underline--link{% else %}button button-{{ block.settings.button_style }} button-{{ block.settings.btn_size }} hover-{{ block.settings.hover_effect }}{% endif %}"
                    >
                      <span class="button-text">{{ block.settings.btn_text }}</span>
                      {% if block.settings.button_style == 'text' %}
                        <span class="link-arrow">
                          <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentColor"/>
                          </svg>
                        </span>
                      {% endif %}
                    </a>
                  </div>
                {% endif %}
            {% endcase %}
          {% endfor %}
        </div>
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'description' %}
              {%- if block.settings.description != blank -%}
                <div class="description rich-text--text text-{{ block.settings.description_size }} rte">
                  {{ block.settings.description | replace: '<p></p>', '<br>' }}
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;

  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
    }

  }
</style>
{% schema %}
{
  "name": "t:sections.rich-text.name",
   "tag": "section",
  "class":"section-rich-text",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
      {
        "type": "color_scheme",
        "id":"color_scheme",
       "label": "t:global.color_scheme.label", 
        "default":"scheme-2"
      },
      {
        "type": "text_alignment",
        "id": "content_alignment",
        "label": "t:global.content_alignment.label",
        "default": "center"
      },
      {
        "type": "select",
        "id":"option_style",
        "label": "t:sections.rich-text.settings.option_style.label",
        "options": [
           {
      "label": "t:sections.rich-text.settings.option_style.options.none.label",
      "value": "none"
    },
    {
      "label": "t:sections.rich-text.settings.option_style.options.collage.label",
      "value": "collage"
    }
        ]
      },
      {
        "type": "select",
        "id":"content_width",
        "label": "t:sections.rich-text.settings.content_width.label",
        "default":"medium",
        "options": [
          {
      "label": "t:sections.rich-text.settings.content_width.options.small.label",
      "value": "small"
    },
    {
      "label": "t:sections.rich-text.settings.content_width.options.medium.label",
      "value": "medium"
    },
    {
      "label": "t:sections.rich-text.settings.content_width.options.large.label",
      "value": "large"
    }
        ]
      },
      {
    "type": "header",
    "content": "t:global.section_spacing.content"
    },
    {
    "type": "range",
    "id": "top_space_desktop",
    "label": "t:global.section_spacing.top_space_desktop.label",
    "default": 100,
    "min": 0,
    "max": 150,
    "step": 5
  },
  {
    "type": "range",
    "id": "bottom_space_desktop",
     "label": "t:global.section_spacing.bottom_space_desktop.label",
    "default": 100,
    "min": 0,
    "max": 150,
    "step": 5
  },
  {
    "type": "range",
    "id": "top_space_mobile",
    "label": "t:global.section_spacing.top_space_mobile.label",
    "default": 60,
    "min": 0,
    "max": 100,
    "step": 5
  },
  {
    "type": "range",
    "id": "bottom_space_mobile",
     "label": "t:global.section_spacing.bottom_space_mobile.label",
    "default": 60,
    "min": 0,
    "max": 100,
    "step": 5
  }
  ],
   "blocks": [
    {
      "type": "heading",
      "name": "t:sections.rich-text.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
           "label": "t:global.general_label.heading.label",
          "default": "Talk about your brand"
        },
        {
          "type": "select",
          "id": "heading_size",
          "default": "h3",
          "label": "t:global.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:global.heading_size.options.h1.label"
        },
        {
          "value": "h2",
         "label": "t:global.heading_size.options.h2.label"
        },
        {
          "value": "h3",
         "label": "t:global.heading_size.options.h3.label"
        },
        {
          "value": "h4",
        "label": "t:global.heading_size.options.h4.label"
        },
        {
          "value": "h5",
          "label": "t:global.heading_size.options.h5.label"
        },
        {
          "value": "h6",
        "label": "t:global.heading_size.options.h6.label"
        }
      ]
        },
        {
          "type": "select",
          "id": "heading_seo",
          "default": "h1",
           "label": "t:global.heading_seo.label",
      "info": "t:global.heading_seo.info",
      "options": [
         {
            "value": "h1",
            "label": "t:global.heading_seo.options.h1.label"
          },
          {
            "value": "h2",
           "label": "t:global.heading_seo.options.h2.label"
          },
          {
            "value": "h3",
           "label": "t:global.heading_seo.options.h3.label"
          },
          {
            "value": "h4",
          "label": "t:global.heading_seo.options.h4.label"
          },
          {
            "value": "h5",
            "label": "t:global.heading_seo.options.h5.label"
          },
          {
            "value": "h6",
          "label": "t:global.heading_seo.options.h6.label"
          }
        ]
        }
      ]
    },
    {
      "type": "description",
      "name": "t:sections.rich-text.blocks.description.name",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "description",
        "label": "t:global.general_label.description.label",
          "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>"
        },
        {
          "type": "select",
          "id": "description_size",
          "default": "text-lg",
         "label": "t:global.description_size.label",
          "options": [
            {
              "value": "text-xl",
              "label": "t:global.description_size.options.x-large.label"
            },
            {
              "value": "text-lg",
              "label": "t:global.description_size.options.large.label"
            },
            {
              "value": "text-base",
              "label": "t:global.description_size.options.medium.label"
            },
            {
              "value": "text-sm",
              "label": "t:global.description_size.options.small.label"
            },
            {
              "value": "text-xs",
              "label": "t:global.description_size.options.x-small.label"

            }
          
          ]
        },
      ]
    },
    {
      "type": "button",
      "name": "t:sections.rich-text.blocks.button.name",
      "settings": [
       {
          "type": "text",
          "id": "btn_text",
            "label": "t:global.general_label.text.label",
          "default":"Shop now"
        },
        {
          "type": "url",
          "id": "btn_link",
         "label": "t:global.general_label.link.label"
        },
        {
          "type": "select",
          "id": "btn_size",
               "default": "sm",
            "label": "t:global.btn_size.label",
          "options": [
           {
              "label": "t:global.btn_size.options.xsmall.label",
              "value": "xsm"

            },
            {
             "label": "t:global.btn_size.options.small.label",
              "value": "sm"

            },
            {
              "label": "t:global.btn_size.options.medium.label",
              "value": "md"

            },
            {
             "label": "t:global.btn_size.options.large.label",
              "value": "lg"

            }
          
          ]
        },
        {
          "type":"select",
          "id":"button_style",
           "label": "t:global.button_style.label",
          "options": [
            {
              "label": "t:global.button_style.options.solid.label",
              "value": "solid"
            },
            {
              "label": "t:global.button_style.options.outline.label",
              "value": "outline"
            },
            {
              "label": "t:global.button_style.options.text.label",
              "value":"text"
            }
          ]
        },
        {
          "type": "select",
          "id":"hover_effect",
          
          "label": "t:global.hover_effect.label",
          "options": [
            {
              "label": "t:global.hover_effect.options.standard.label",
              "value": "standard"
            },
            {
              "label": "t:global.hover_effect.options.none.label",
              "value": "none"
            }
          ] 
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.rich-text.presets.name",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "description"
        }
      ]
    }
  ]
}
{% endschema %}
