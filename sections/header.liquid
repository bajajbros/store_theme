{{ 'header.css' | asset_url | stylesheet_tag }}
<main-header class="main-header--wrapper {% if section.settings.bg_enable %} header-bg-enable{% endif %} {{ section.settings.sticky_header }} {% if section.settings.transparent_header and template == 'index'%} transparent{% endif %} {% if  section.settings.sticky_header =='on_scroll_up' %}is-sticky{% endif %}">
  <div class="page--width">
    {% capture logo %}
      <div class="header-item site--logo">
        <a class="logo-image--wrapper" href="{{ routes.root_url }}">
          {%- if settings.logo != blank -%}
            {% render 'logo' %}
          {% else %}
            <span class="h4">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>
    {% endcapture %}
    <div class="site-navbar menu-with-toggle {{ section.settings.desktop_menu_position }}">
         {% render 'mobile-menu', section: section %}
      {% if section.settings.desktop_menu_position == 'logo-left-menu--left'
        or section.settings.desktop_menu_position == 'logo-left-menu--center'
        or section.settings.desktop_menu_position == 'logo-left-menu--right'
        or section.settings.desktop_menu_position == 'logo-left-menu--drawer'
      %}
        {{ logo }}
      {% endif %}
      <div class="header-item site--navigation">
      <header-drawer class="drawer-toggle" {% if section.settings.menu == blank and section.settings.desktop_menu_position == 'logo-center-menu--drawer' or section.settings.desktop_menu_position == 'logo-left-menu--drawer' %}style="display:flex;"{% endif %} data-drawer-head>
        <button class="drawer-toggle-button" aria-label="hamburger menu">
          <svg
            class="svg--menu"
            xmlns="http://www.w3.org/2000/svg"
            xmlns:xlink="http://www.w3.org/1999/xlink"
            x="0px"
            y="0px"
            width="16px"
            height="14px"
            viewBox="0 0 16 14"
            style="enable-background:new 0 0 16 14;"
            xml:space="preserve"
          >
            <line x1="1" y1="1" x2="15" y2="1"></line><line x1="1" y1="7" x2="15" y2="7"></line><line x1="1" y1="13" x2="15" y2="13"></line>
          </svg>
          <svg
            class="svg--close"
            xmlns="http://www.w3.org/2000/svg"
            xmlns:xlink="http://www.w3.org/1999/xlink"
            x="0px"
            y="0px"
            width="13px"
            height="13px"
            viewBox="0 0 13 13"
            style="enable-background:new 0 0 13 13;"
            xml:space="preserve"
          >
            <line x1="1.3" y1="11.7" x2="11.7" y2="1.3"></line><line x1="11.7" y1="11.7" x2="1.3" y2="1.3"></line>
          </svg>
        </button>
      </header-drawer>
        {% render 'menu-items', section: section %}
      </div>
      {% if section.settings.desktop_menu_position == 'logo-center-menu--left'
        or section.settings.desktop_menu_position == 'logo-center-menu--drawer'
      %}
        {{ logo }}
      {% endif %}
      {% render 'header-icon', section: section %}

   
    </div>
  </div>
</main-header>
{% if section.settings.desktop_menu_position == 'logo-center-menu--drawer'
  or section.settings.desktop_menu_position == 'logo-left-menu--drawer'
%}
  {% render 'menu-drawer', section: section %}
{% endif %}
{% unless request.page_type == 'search' %}
  {%- render 'search-model' -%}
{% endunless %}



