{{ 'compact-categories.css' | asset_url | stylesheet_tag }}
<div class="compact-categories-section section-gap color-{{ section.settings.color_scheme }}">
  {% if section.settings.background_image != blank %}
    <div class="background-image">
      {%- liquid
        assign height = section.settings.background_image.width | divided_by: section.settings.background_image.aspect_ratio | round
        assign sizes = '100vw'
        assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      -%}
      {{
        section.settings.background_image
        | image_url: width: 3840
        | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: widths
      }}
    </div>
  {% endif %}
  <div class="page--width">
    {% if section.blocks.size > 0 %}
      <div class="compact-categories-wrap media-width--{{ section.settings.content_width }}">
        <ul class="compact-categories-grid">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'category' %}
                {% assign collection = block.settings.collection %}
                {% if collection != blank %}
                  <li>
                    <a
                      href="{{ collection.url }}"
                      class="compact-categories--text {{ section.settings.content_size }}"
                      aria-label="
                        {%- if block.settings.heading != blank -%}
                          {{- block.settings.heading -}}
                        {%- elsif collection != blank -%}
                          {{- collection.title -}}
                        {%- endif %}
                      "
                    >
                      <svg-button class="{% if block.settings.text_style == 'line' %} compact-categories--line{% elsif block.settings.text_style == 'image' %}compact-categories--hover-on-image{% endif %} ">
                        <span>
                          {%- if block.settings.heading != blank -%}
                            {{- block.settings.heading -}}
                          {%- elsif collection != blank -%}
                            {{- collection.title -}}
                          {%- endif %}
                        </span>
                        <div class="svg-wrapper"></div>
                        {% if block.settings.text_style == 'line' %}
                         <svg class="progress-line" viewBox="0 0 400 80" preserveAspectRatio="xMidYMid meet">
                          <rect
                            x="2"
                            y="0"
                            rx="24"
                            ry="24"
                            width="396"
                            height="80"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1"
                            stroke-miterlimit="10"
                          />
                        </svg>


                        {% endif %}
                        {% if block.settings.text_style == 'image' %}
                          {% if collection.featured_image != blank %}
                            <div class="compact-categories-image-hover">
                              {%- assign widths = '100, 155, 300, 535, 750, 1070' -%}
                              {%- capture sizes -%}
                        (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                      {%- endcapture -%}
                              {{
                                collection.featured_image
                                | image_url: width: 1500
                                | image_tag: sizes: sizes, widths: widths
                              }}
                            </div>
                          {% endif %}
                        {% endif %}
                      </svg-button>
                    </a>
                  </li>
                {% else %}
                  <li>
                    <div
                      class="compact-categories--text {{ section.settings.content_size }}"
                    >
                      <svg-button class="{% if block.settings.text_style == 'line' %} compact-categories--line{% elsif block.settings.text_style == 'image' %}compact-categories--hover-on-image{% endif %} ">
                        <span>
                          {{ 'onboarding.compact_title' | t }}
                        </span>
                        <div class="svg-wrapper"></div>
                        {% if block.settings.text_style == 'line' %}
                          <svg class="progress-line hide-item  hidden" viewBox="0 0 400 80">
                            <rect x="10" y="0" rx="24" ry="24" width="400" height="80" fill="none" stroke="currentColor" stroke-miterlimit="100"></rect>
                          </svg>
                        {% endif %}
                        {% if block.settings.text_style == 'image' %}
                          {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                          {%- assign placeholder_image = 'collection-apparel-' | append: current -%}
                          <div class="compact-categories-image-hover">
                            {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                          </div>
                        {% endif %}
                      </svg-button>
                    </div>
                  </li>
                {% endif %}
              {% when 'image' %}
                <li>
                  <a
                    {% if block.settings.link == blank %}
                      disabled="true"
                      href="#"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                    class="categories-image img--{{ block.settings.image_size }}"
                    aria-label="{{ 'onboarding.compact_title' | t }}"
                  >
                    <div class="categories-image-media">
                      {% if block.settings.image != blank %}
                        {%- assign widths = '100, 155, 300, 535, 750, 1070' -%}
                        {%- capture sizes -%}
                        (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                      {%- endcapture -%}
                        {{ block.settings.image | image_url: width: 1500 | image_tag: sizes: sizes, widths: widths }}
                      {% else %}
                        {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                        {%- assign placeholder_image = 'collection-apparel-' | append: current -%}
                        {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </div>
                  </a>
                </li>
            {% endcase %}
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;
     --grid-gap:{{ section.settings.column_gap }}px;

  }
  #shopify-section-{{ section.id }} .background-image{
     --background-color-overlay: {{ section.settings.overlay_color.rgb }};
     --overlay-color-opacity: {{ section.settings.overlay_opacity }}%;
  }


  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
       --grid-gap:{{ section.settings.column_gap_mobile }}px;
    }

  }
</style>
{% schema %}
{
  "name": "t:sections.compact-categories.name",
   "tag": "section",
  "class":"section-compact-categories",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
     {
          "type": "color_scheme",
          "id":"color_scheme",
          "label": "t:global.color_scheme.label",
          "default":"scheme-2"
      },
     {
        "type":"image_picker",
        "id":"background_image",
        "label": "t:global.general_label.background_image.label"
      },
    {
        "type": "range",
        "id":"column_gap",
        "label": "t:global.general_label.column_gap.label",
        "min":0,
        "max":50,
        "default":35,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "range",
        "id":"column_gap_mobile",
       "label": "t:global.general_label.column_gap_mobile.label",
        "min":0,
        "max":50,
        "default":20,
        "step": 1,
        "unit": "px"
      },
      {
        "type": "select",
        "id":"content_width",
        "default":"large",
        "label": "t:global.content_width.label",
        "options": [
           {
              "label": "t:global.content_width.options.small.label",
              "value": "small"
            },
            {
              "label": "t:global.content_width.options.medium.label",
              "value": "medium"
            },
            {
              "label": "t:global.content_width.options.large.label",
              "value": "large"
            },
        ]
      },
      {
        "type": "select",
        "id": "content_size",
        "default": "h1",
       "label": "t:global.heading_size.label",
          "options": [
          {
            "value": "h1",
            "label": "t:global.heading_size.options.h1.label"
          },
          {
            "value": "h2",
          "label": "t:global.heading_size.options.h2.label"
          },
          {
            "value": "h3",
          "label": "t:global.heading_size.options.h3.label"
          },
          {
            "value": "h4",
          "label": "t:global.heading_size.options.h4.label"
          }
          ]
      },
      {
        "type": "header",
        "content": "t:global.header.color.content"
      },
      {
        "type": "color",
        "id": "overlay_color",
        "default": "#000000",
        "label": "t:global.general_label.overlay_color.label"
      },
     {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:global.general_label.overlay_opacity.label",
      "default": 50,
       "min": 0,
       "max": 100,
      "step": 1,
       "unit": "%"
      },
      {
      "type": "header",
       "content": "t:global.section_spacing.content"
      },
      {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.section_spacing.top_space_desktop.label",
      "default": 120,
      "min": 0,
      "max": 150,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.section_spacing.bottom_space_desktop.label",
      "default": 120,
      "min": 0,
      "max": 150,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
       "label": "t:global.section_spacing.top_space_mobile.label",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.section_spacing.bottom_space_mobile.label",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
     "type":"category",
      "name":"t:sections.compact-categories.blocks.name",
      "settings": [
        {
          "type":"collection",
          "id":"collection",
          "label":"t:sections.compact-categories.blocks.settings.collection.label"
        },
        {
          "type": "text",
          "id":"heading",
         "label":"t:sections.compact-categories.blocks.settings.heading.label"
        },
         {
          "type": "select",
          "id":"text_style",
         "label":"t:sections.compact-categories.blocks.settings.text_style.label",
          "default":"line",
          "options": [
            {
              "value":"none",
              "label":"t:sections.compact-categories.blocks.settings.text_style.options.none.label",
            },
            {
              "value": "line",
              "label": "t:sections.compact-categories.blocks.settings.text_style.options.line.label"
            },
            {
              "value": "image",
              "label": "t:sections.compact-categories.blocks.settings.text_style.options.image.label"
            }
          ]
        },
      ]
    },
    {
      "type":"image",
      "name":"t:sections.compact-categories.blocks.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id":"image",
          "label": "t:global.general_label.image.label"
        },
        {
            "type": "url",
            "id": "link",
            "label": "t:global.general_label.link.label"
        },
        {
          "type": "select",
          "id": "image_size",
          "label": "t:global.image_size_option.label",
          "default": "medium",
          "options": [
            {
              "value": "small",
               "label": "t:global.image_size_option.small.label"
            },
            {
              "value": "medium",
              "label": "t:global.image_size_option.medium.label"
            },
            {
              "value": "large",
              "label": "t:global.image_size_option.large.label"
            }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name":"t:sections.compact-categories.presets.name",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "image"
        },
        {
          "type": "category"
        }
      ]
    }
  ]

}
{% endschema %}
