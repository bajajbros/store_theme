<div class="404-section section-gap color-{{ section.settings.color_scheme }}">
  <div class="404-inner">
    <div class="page--width text-align-center">
      {% if section.settings.heading != blank %}
        <{{ section.settings.heading_seo }} class="title {{ section.settings.heading_size }}">
          {{- section.settings.heading -}}
        </{{ section.settings.heading_seo }}>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="{{ section.settings.description_size }} rte">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {%- if section.settings.btn_text != blank and section.settings.btn_link != blank -%}
        <a
          href="{{ section.settings.btn_link }}"
          class="{% if section.settings.button_style == 'text' %}underline--link{% else %}{{ settings.button_font }}-font button button-{{ section.settings.button_style }} button-{{ section.settings.btn_size }} hover-{{ section.settings.hover_effect }}{% endif %}"
        >
          <span class="button-text">{{ section.settings.btn_text }}</span>
          {% if section.settings.button_style == 'text' %}
            <span class="link-arrow">
              <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentColor"/>
              </svg>
            </span>
          {% endif %}
        </a>
      {% endif %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;

  }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;

    }

  }
</style>
