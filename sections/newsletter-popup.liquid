{% if section.settings.newsletter_enable %}
  <subscription-popup
    class="modal-wrapper subscription-popup modal-with-image-left color-{{ section.settings.color_scheme }} {% if section.settings.newsletter_img == blank %} newsletter-without-img{% endif %}"
    data-subscriptionpopup="true"
  >
    <div class="modal-overlay" data-popup-close></div>
    <div class="modal-content">
      <button class="modal-close-btn" aria-label="Close" data-popup-close aria-expanded="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
          class="icon-close"
          fill="none"
          viewBox="0 0 24 24"
        >
          <path d="M18.75 5.13496L5.25 18.8544" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
          <path d="M18.75 18.8544L5.25 5.13496" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>
      <div class="modal-body">
        <div class="subscription-modal--card flex wrap text-align-center">
          {% if section.settings.newsletter_img != blank %}
            <div class="subscription-modal-image w-100">
              {% assign image = section.settings.newsletter_img %}
              <img
                srcset="
                  {%- if image.width >= 165 -%}{{ image | image_url: width: 165 }} 165w,{%- endif -%}
                  {%- if image.width >= 330 -%}{{ image | image_url: width: 330 }} 330w,{%- endif -%}
                  {%- if image.width >= 535 -%}{{ image | image_url: width: 535 }} 535w,{%- endif -%}
                  {%- if image.width >= 850 -%}{{ image | image_url: width: 850 }} 850w,{%- endif -%}
                  {%- if image.width >= 1000 -%}{{ image | image_url: width: 1000 }} 1000w,{%- endif -%}
                  {%- if image.width >= 1500 -%}{{ image | image_url: width: 1500 }} 1500w,{%- endif -%}
                  {%- if image.width >= 3000 -%}{{ image | image_url: width: 3000 }} 3000w,{%- endif -%}
                  {{ image | image_url }} {{ image.width }}w
                "
                src="{{ image | image_url: width: 1500 }}"
                sizes="calc(100vw - 3rem)"
                alt="{{ image.alt | escape }}"
                height="{{ image.height }}"
                width="{{ image.width }}"
                loading="lazy"
              >
            </div>
          {% endif %}
          <div class="subscription-popup-block w-100 flex column justify-content-center">
            <div class="subscription_pop_in">
              {% if section.settings.newsletter_subheading != blank %}
              <span class="pop_sub_head">{{ section.settings.newsletter_subheading }}</span>
            {% endif %}
            {% if section.settings.newsletter_heading != blank %}
              <div class="subscription-popup-title">
                <h4 class="h4">{{ section.settings.newsletter_heading }}</h4>
              </div>
            {% endif %}
            <div class="subscription-popupform">
              {% assign formid = 'contact_form' | append: section.id %}
              {%- form 'customer', id: formid, class: 'signup-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="hidden" name="contact[context]" value="newsletter_popup">
                {%- if form.posted_successfully? -%}
                  {%- if section.id contains 'popup' -%}
                    <div id="newsletter-success--{{ section.id }}" role="alert" class="alert 1form-success-message alert-success" tabindex="-1">
                      {{- 'newsletter.success' | t -}}
                    </div>
                  {%- endif -%}
                {%- endif -%}
                 {%- if form.errors -%}
                    {%- if section.id contains 'popup' -%}
                      <div id="newsletter-error--{{ section.id }}" role="alert" class="alert alert-warning" tabindex="-1">
                        {{- form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email -}}
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                <div class="form-control">
                  <label for="NewsletterCustomerEmail-{{section.id}}" class="hidden">
                    {{- 'newsletter.label' | t -}}
                  </label>
                  <input
                    id="NewsletterCustomerEmail-{{section.id}}"
                    class="input"
                    type="email"
                    name="contact[email]"
                    autocomplete="email"
                    autocapitalize="off"
                    {%- if form.errors -%}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="Newsletter-error-{{ section.id }}"
                    {%- elsif form.posted_successfully? -%}
                      aria-describedby="Newsletter-success-{{ section.id }}"
                    {%- endif -%}
                    placeholder="{{'newsletter.label' | t}}"
                    pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)*[a-zA-Z]{2,}))$"
                    required
                  >
                </div>
                <button
                  type="submit"
                  class="button button-md w-100 {{ settings.button_font }}-font"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  {{ 'newsletter.button_label' | t }}
                </button>
              {% endform %}
            </div>
            {% if section.settings.newsletter_content != blank %}
              <div class="subscription-popup--text rte text-sm">
                {{ section.settings.newsletter_content }}
              </div>
            {% endif %}
            {% if section.settings.enable_social_media %}
              <ul class="flex align-items-center social-icons wrap justify-content-center" role="list">
                {% render 'social-icons' %}
              </ul>
            {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </subscription-popup>
  <script src="{{ 'newsletter-popup.js' | asset_url }}" defer></script>
{% endif %}
{% schema %}
{
  "name": "t:sections.newsletter_popup.name",
  "settings": [
      {
        "type": "color_scheme",
        "id":"color_scheme",
        "label": "t:global.color_scheme.label",
        "default":"scheme-1"
      },
      {
  "type": "checkbox",
  "id": "newsletter_enable",
  "label": "t:sections.newsletter_popup.settings.newsletter_enable.label",
  "default": false
},
{
  "type": "checkbox",
  "id": "enable_social_media",
  "label": "t:sections.newsletter_popup.settings.enable_social_media.label",
  "default": false
},
{
  "type": "image_picker",
  "id": "newsletter_img",
  "label": "t:sections.newsletter_popup.settings.newsletter_img.label"
},
{
  "type": "text",
  "id": "newsletter_subheading",
  "label": "t:sections.newsletter_popup.settings.newsletter_subheading.label",
  "default": "Subheading"
},
{
  "type": "text",
  "id": "newsletter_heading",
  "label": "t:sections.newsletter_popup.settings.newsletter_heading.label",
  "default": "Get news and offers"
},
{
  "type": "richtext",
  "id": "newsletter_content",
  "label": "t:sections.newsletter_popup.settings.newsletter_content.label",
  "default": "<p>Sign up for newsletter</p>"
},
{
  "type": "range",
  "id": "popup_cookie_set",
  "min": 1,
  "max": 30,
  "step": 1,
  "label": "t:sections.newsletter_popup.settings.popup_cookie_set.label",
  "info": "t:sections.newsletter_popup.settings.popup_cookie_set.info",
  "default": 5
}
  ]
}
{% endschema %}
