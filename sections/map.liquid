        },
         {
          "value": "750",
       "label": "t:global.image_height.options.x-large.label"
        },
        {
          "value": "full",
            "label": "t:global.image_height.options.full.label"
        }
      ]

    },
    {
      "type": "select",
      "id": "mobile_image_height",
      "default": "300",
       "label": "t:sections.map.settings.mobile_image_height.label",
      "options": [
        {
          "value": "300",
          "label": "t:global.image_height.options.small.label"
        },
        {
          "value": "350",
             "label": "t:global.image_height.options.medium.label"
