<map-section class="block map-section color-{{ section.settings.color_scheme }} section-gap">
  <div class="map-card">
    {% if section.settings.heading != blank
      or collection != blank
      and section.settings.show_collection_title
      or section.settings.description != blank
    %}
      <div class="page--width">
        <heading-main class="main-heading">
          {% if section.settings.heading != blank %}
            <{{ section.settings.heading_seo }} class="section-title {{ section.settings.heading_size }}">
              {% if section.settings.heading != blank -%}
                {{- section.settings.heading -}}
              {% endif %}
            </{{ section.settings.heading_seo }}>
          {% endif %}
          {% if section.settings.description != blank %}
            <div class="section-description {{ section.settings.description_size }}">
              {{ section.settings.description | newline_to_br }}
            </div>
          {% endif %}
        </heading-main>
      </div>
    {% endif %}
    <div class="media-ratio desktop-height--{{ section.settings.image_height }} mobile-height--{{ section.settings.mobile_image_height }}">
      {% if section.settings.map_iframe != blank %}
        {{ section.settings.map_iframe }}
      {% endif %}
    </div>
  </div>
</map-section>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;

  }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;

    }

  }
</style>
{% schema %}
{
  "name": "t:sections.map.name",
   "class": "section-map",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
          "type": "color_scheme",
