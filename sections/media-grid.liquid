{{ 'media-grid.css' | asset_url | stylesheet_tag }}
<media-grid class="block media-grid-section section-gap color-{{ section.settings.color_scheme }}">
  <div class="{% if section.settings.fullwidth %} page--width-full{% else %}page--width{% endif %}">
    {% if section.blocks.size > 0 %}
      <media-grid class="media-grid--grid"> 
        {% for block in section.blocks %}
          <div
            id="media-grid--item-{{ block.id }}"
            class="media-grid--item {% if block.settings.video_on_hover %}media-grid--hover{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="media-grid--img">
              {% if block.settings.video != blank %}
                <deferred-media
                  class="deferred-media autoplay-true"
                  data-autoplay="true"
                >
                  <template style="display:none">
                    {{
                      block.settings.video
                      | video_tag:
                        image_size: '1200x',
                        class: 'media-grid--video',
                        autoplay: true,
                        loop: true,
                        controls: false,
                        muted: true
                    }}
                  </template>
                  <noscript>
                    {{
                      block.settings.video
                      | video_tag:
                        image_size: '1100x',
                        class: 'media-grid--video',
                        autoplay: true,
                        loop: true,
                        controls: false,
                        muted: true
                    }}
                  </noscript>
                </deferred-media>
              {% endif %}
              {% if block.settings.media_image != blank %}
                {% assign image = block.settings.media_image %}
                <img
                  srcset="
                    {%- if image.width >= 165 -%}{{ image | image_url: width: 165 }} 165w,{%- endif -%}
                    {%- if image.width >= 330 -%}{{ image | image_url: width: 330 }} 330w,{%- endif -%}
                    {%- if image.width >= 535 -%}{{ image | image_url: width: 535 }} 535w,{%- endif -%}
                    {%- if image.width >= 850 -%}{{ image | image_url: width: 850 }} 850w,{%- endif -%}
                    {%- if image.width >= 1000 -%}{{ image | image_url: width: 1000 }} 1000w,{%- endif -%}
                    {%- if image.width >= 1500 -%}{{ image | image_url: width: 1500 }} 1500w,{%- endif -%}
                    {%- if image.width >= 3000 -%}{{ image | image_url: width: 3000 }} 3000w,{%- endif -%}
                    {{ image | image_url }} {{ image.width }}w
                  "
                  src="{{ image | image_url: width: 1500 }}"
                  sizes="calc(100vw - 3rem)"
                  alt="{{ image.alt | escape }}"
                  height="{{ image.height }}"
                  width="{{ image.width }}"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.media_image == blank
                and block.settings.video_on_hover
                or block.settings.media_image == blank
                and block.settings.video == blank
              %}
                {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>

            <div class="media-grid-content--wrapper text-align-{{ block.settings.desktop_alignment }} text-align-m--{{ block.settings.mobile_alignment }} content-{{ block.settings.content_position }} content-m-{{ block.settings.content_position_mobile }}">
              <div class="media-grid--inner media-width--{{ block.settings.content_width }}">
                {% if block.settings.heading != blank or block.settings.description != blank %}
                  {% if block.settings.heading != blank %}
                    <{{ block.settings.heading_seo }} class="media-grid--title {{ block.settings.heading_size }}">
                      {{- block.settings.heading -}}
                    </{{ block.settings.heading_seo }}>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <div class="description {{ block.settings.description_size }}">
                      {{ block.settings.description | newline_to_br }}
                    </div>
                  {% endif %}
                {% endif %}
                {%- if block.settings.btn_text != blank and block.settings.btn_link != blank -%}
                  <a
                    href="{{ block.settings.btn_link }}"
                    class="{% if block.settings.button_style == 'text' %}underline--link{% else %}{{ settings.button_font }}-font button button-{{ block.settings.button_style }} button-{{ block.settings.btn_size }} hover-{{ block.settings.hover_effect }}{% endif %}"
                  >
                    <span class="button-text">{{ block.settings.btn_text }}</span>
                    {% if block.settings.button_style == 'text' %}
                      <span class="link-arrow">
                        <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentColor"/>
                        </svg>
                      </span>
                    {% endif %}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </media-grid>
    {% endif %}
  </div>
</media-grid>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;
    --grid-gap:{{ section.settings.grid_gap }}px;
    --grid-height-desktop:{{ section.settings.desktop_height}}px;
    --grid-height-mobile:{{ section.settings.mobile_height}}px;
  }

   {% if section.blocks.size > 0 %}
     {% for block in section.blocks %}
       #media-grid--item-{{ block.id }}{
          --media-grid-text:{{ block.settings.text_color.red }},{{ block.settings.text_color.green }},{{ block.settings.text_color.blue }};
          --background-color-overlay: {{ block.settings.overlay_color.red }} {{ block.settings.overlay_color.green }} {{ block.settings.overlay_color.blue }};
          --overlay-color-opacity: {{ block.settings.overlay_opacity | divided_by:100.0 }};
       }

     {% endfor %}
   {% endif %}

     @media only screen and (min-width:768px) {
     {% if section.blocks.size > 0 %}
       {% for block in section.blocks %}
         #media-grid--item-{{ block.id }}{
            --grid-row-span: {{ block.settings.column}};
            --grid-column-span:{{ block.settings.row }};
         }

       {% endfor %}
     {% endif %}
  }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
    }
    {% if section.blocks.size > 0 %}
     {% for block in section.blocks %}
       #media-grid--item-{{ block.id }}{
          --grid-row-span: {{ block.settings.column_mobile}};
          --grid-column-span:{{ block.settings.row_mobile }};
       }

     {% endfor %}
   {% endif %}
  }
</style>
