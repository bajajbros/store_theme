     "label": "t:global.section_spacing.bottom_space_mobile.label",
    "default": 40,
    "min": 0,
    "max": 100,
    "step": 5
  }
  ],
  "presets": [
    {
       "name":"t:sections.featured-collection-list.presets.name"
    }

  ]
}
{% endschema %}
