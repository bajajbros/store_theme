      "label": "t:sections.featured-collection-list.settings.enable_border.label",
      "default":true
    },
    {
        "type":"select",
        "id":"border_type",
       "label": "t:sections.featured-collection-list.settings.border_type.label",
        "default":"round",
        "options": [
          {
            "label": "t:sections.featured-collection-list.settings.border_type.options.round.label",
            "value": "round"
          },
          {
            "label": "t:sections.featured-collection-list.settings.border_type.options.square.label",
            "value": "square"
          }
        ]
    },
    {
      "type": "select",
