          "value": "medium"
        },
        {
        "label": "t:global.image_size_option.large.label",
          "value": "large"
        }
      ]
    },
     {
          "type": "select",
          "id": "mobile_item_per_row",
          "label": "t:sections.featured-collection-list.settings.mobile_item_per_row.label",
          "default":"2",
          "options": [
            {
              "label": "t:sections.featured-collection-list.settings.mobile_item_per_row.options.options__1.label",
              "value": "1"
            },
             {
              "label": "t:sections.featured-collection-list.settings.mobile_item_per_row.options.options__2.label",
              "value": "2"
            }
          ]
    },
    {
        "type": "range",
