{{ 'featured-collection-list.css' | asset_url | stylesheet_tag }}
<div class="featured-list-section section-gap color-{{ section.settings.color_scheme }}">
  <div class="page--width">
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <heading-main class="main-heading text-align-{{ section.settings.content_alignment }}">
        {% if section.settings.heading != blank %}
          <{{ section.settings.heading_seo }} class="section-title {{ section.settings.heading_size }}">
            {% if section.settings.heading != blank -%}
              {{- section.settings.heading -}}
            {% endif %}
          </{{ section.settings.heading_seo }}>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="section-description {{ section.settings.description_size }}">
            {{ section.settings.description | newline_to_br }}
          </div>
        {% endif %}
      </heading-main>
    {% endif %}
    <div class="featured-list--wrapper text-align-{{ section.settings.content_alignment }}">
      {% if section.settings.collection_list != blank %}
        {% for collection_card in section.settings.collection_list %}
          <div class="featured-item--text {% if section.settings.image_position=="center" %}content-below{% endif %} {% if section.settings.enable_background %}background--true{% endif %} {% if section.settings.enable_border %}border--enable border-{{ section.settings.border_type }}{% endif %}">
            <a href="{{ collection_card.url }}">
              <span class="featured-image {{  section.settings.image_size}}--img">
                {%- if collection_card.featured_image -%}
                  <img
                    srcset="
                      {%- if collection_card.featured_image.width >= 165 -%}{{ collection_card.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
                      {%- if collection_card.featured_image.width >= 330 -%}{{ collection_card.featured_image | image_url: width: 330 }} 330w,{%- endif -%}
                      {%- if collection_card.featured_image.width >= 535 -%}{{ collection_card.featured_image | image_url: width: 535 }} 535w,{%- endif -%}
                      {{ collection_card.featured_image | image_url }} {{ collection_card.featured_image.width }}w
                    "
                    src="{{ collection_card.featured_image | image_url: width: 535 }}"
                    sizes="(min-width: 750px) calc(100vw - 10rem),calc(100vw - 3rem)"
                    alt="{{ collection_card.featured_image.alt | escape }}-{{ forloop.index }}"
                    height="{{ collection_card.featured_image.height }}"
                    width="{{ collection_card.featured_image.width }}"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </span>
              {{- collection_card.title -}}
            </a>
          </div>
        {% endfor %}
      {% else %}
        {% assign limit = 6 %}
        {% for i in (1..limit) %}
          {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
          {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
          <div class="featured-item--text {% if section.settings.image_position=="center" %}content-below{% endif %} {% if section.settings.enable_background %}background--true{% endif %} {% if section.settings.enable_border %}border--enable border-{{ section.settings.border_type }}{% endif %}">
            <div>
              <span class="featured-image {{  section.settings.image_size}}--img">
                {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
              </span>
              {{ 'onboarding.collection_title' | t }}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;
    --grid-gap:{{ section.settings.column_gap }}px;
  }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
      --grid-gap:{{ section.settings.column_gap_mobile }}px;
      --grid-item-per-row:{{ section.settings.mobile_item_per_row }};
    }

  }
</style>
{% schema %}
{
