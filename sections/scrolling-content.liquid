{{ 'scrolling-content.css' | asset_url | stylesheet_tag }}
<scrolling-content class="block scrolling-content-section color-{{ section.settings.color_scheme }}">
  <div class="grid grid-col-2 content-container">
    {% if section.blocks.size > 0 %}
      <div class="left-content scrolling-content--grid ">
        <div class="main-swipper-scroll swiper-container swiper mobile-hidden">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'text' -%}
                  <div class="swiper-slide">
                    <div class="scrolling-content--img" id="content-{{block.id  }}">
                      <div class="media-ratio">
                        {%- if block.settings.image != blank -%}
                          {% assign image_url = block.settings.image %}
                          <img
                            srcset="
                              {%- if image_url.width >= 165 -%}{{ image_url | image_url: width: 165 }} 165w,{%- endif -%}
                              {%- if image_url.width >= 330 -%}{{ image_url | image_url: width: 330 }} 330w,{%- endif -%}
                              {%- if image_url.width >= 535 -%}{{ image_url | image_url: width: 535 }} 535w,{%- endif -%}
                              {%- if image_url.width >= 750 -%}{{ image_url | image_url: width: 750 }} 750w,{%- endif -%}
                              {%- if image_url.width >= 1000 -%}{{ image_url | image_url: width: 1000 }} 1000w,{%- endif -%}
                              {%- if image_url.width >= 1500 -%}{{ image_url | image_url: width: 1500 }} 1500w,{%- endif -%}
                              {%- if image_url.width >= 3000 -%}{{ image_url | image_url: width: 3000 }} 3000w,{%- endif -%}
                              {{ image_url | image_url }} {{ image_url.width }}w
                            "
                            src="{{ image_url | image_url: width: 1500 }}"
                            sizes="(min-width: 750px) calc(100vw - 10rem),calc(100vw - 3rem)"
                            alt="{{ image_url.alt | escape }}"
                            height="{{ image_url.height }}"
                            width="{{ image_url.width }}"
                            loading="lazy"
                          >
                        {% else %}
                          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                      </div>
                      <span class="scrolling-cont-number">0{{ forloop.index }}</span>
                    </div>
                  </div>
                {% when 'products' %}
                  <div class="swiper-slide">
                    <div class="scrolling-content--img " id="content-{{block.id  }}">
                      <div class="media-ratio">
                        {%- if block.settings.image != blank -%}
                          {% assign image_url = block.settings.image %}
                          <img
                            srcset="
                              {%- if image_url.width >= 165 -%}{{ image_url | image_url: width: 165 }} 165w,{%- endif -%}
                              {%- if image_url.width >= 330 -%}{{ image_url | image_url: width: 330 }} 330w,{%- endif -%}
                              {%- if image_url.width >= 535 -%}{{ image_url | image_url: width: 535 }} 535w,{%- endif -%}
                              {%- if image_url.width >= 750 -%}{{ image_url | image_url: width: 750 }} 750w,{%- endif -%}
                              {%- if image_url.width >= 1000 -%}{{ image_url | image_url: width: 1000 }} 1000w,{%- endif -%}
                              {%- if image_url.width >= 1500 -%}{{ image_url | image_url: width: 1500 }} 1500w,{%- endif -%}
                              {%- if image_url.width >= 3000 -%}{{ image_url | image_url: width: 3000 }} 3000w,{%- endif -%}
                              {{ image_url | image_url }} {{ image_url.width }}w
                            "
                            src="{{ image_url | image_url: width: 1500 }}"
                            sizes="(min-width: 750px) calc(100vw - 10rem),calc(100vw - 3rem)"
                            alt="{{ image_url.alt | escape }}"
                            height="{{ image_url.height }}"
                            width="{{ image_url.width }}"
                            loading="lazy"
                          >
                        {% else %}
                          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                      </div>

                      <span class="scrolling-cont-number">0{{ forloop.index }}</span>
                      <div class="scrolling-content-wrapper">
                        {% if block.settings.subheading != blank %}
                          <span class="sub-title text-base">{{ block.settings.subheading }}</span>
                        {% endif %}
                        {% if block.settings.heading != blank %}
                          <{{ block.settings.heading_seo }} class="scrolling-content--title {{ block.settings.heading_size }}">
                            {{- block.settings.heading -}}
                          </{{ block.settings.heading_seo }}>
                        {% endif %}
                      </div>
                    </div>
                  </div>

                {% when 'collections' %}
                  <div class="swiper-slide">
                    <div class="scrolling-content--img swiper-slide" id="content-{{block.id  }}">
                      <div class="media-ratio">
                        {%- if block.settings.image != blank -%}
                          {% assign image_url = block.settings.image %}
                          <img
                            srcset="
                              {%- if image_url.width >= 165 -%}{{ image_url | image_url: width: 165 }} 165w,{%- endif -%}
                              {%- if image_url.width >= 330 -%}{{ image_url | image_url: width: 330 }} 330w,{%- endif -%}
                              {%- if image_url.width >= 535 -%}{{ image_url | image_url: width: 535 }} 535w,{%- endif -%}
                              {%- if image_url.width >= 750 -%}{{ image_url | image_url: width: 750 }} 750w,{%- endif -%}
                              {%- if image_url.width >= 1000 -%}{{ image_url | image_url: width: 1000 }} 1000w,{%- endif -%}
                              {%- if image_url.width >= 1500 -%}{{ image_url | image_url: width: 1500 }} 1500w,{%- endif -%}
                              {%- if image_url.width >= 3000 -%}{{ image_url | image_url: width: 3000 }} 3000w,{%- endif -%}
                              {{ image_url | image_url }} {{ image_url.width }}w
                            "
                            src="{{ image_url | image_url: width: 1500 }}"
                            sizes="(min-width: 750px) calc(100vw - 10rem),calc(100vw - 3rem)"
                            alt="{{ image_url.alt | escape }}"
                            height="{{ image_url.height }}"
                            width="{{ image_url.width }}"
                            loading="lazy"
                          >
                        {% else %}
                          {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                      </div>
                      <span class="scrolling-cont-number">0{{ forloop.index }}</span>
                      <div class="scrolling-content-wrapper">
                        {% if block.settings.subheading != blank %}
                          <span class="sub-title text-base">{{ block.settings.subheading }}</span>
                        {% endif %}
                        {% if block.settings.heading != blank %}
                          <{{ block.settings.heading_seo }} class="scrolling-content--title {{ block.settings.heading_size }}">
                            {{- block.settings.heading -}}
                          </{{ block.settings.heading_seo }}>
                        {% endif %}
                      </div>
                    </div>
                  </div>
              {% endcase %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="scrolling-content--grid right-content">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'text' %}
              <div
                class="scrolling-content--item scrolling-content--text color-{{ block.settings.color_scheme }} text-align-{{ block.settings.content_alignment }}"
                data-slide="{{ forloop.index0 }}"
                data-marker-content="content-{{block.id  }}"
                {{ block.shopify_attributes }}
              >
                <div class="mobile-scrolling-contnet desktop-hidden">
                  <div class="scrolling-content--img" id="content-{{block.id  }}">
                    <div class="scrolling-image">
                      {%- if block.settings.image != blank -%}
                        {% assign image_url = block.settings.image %}
                        <img
                          srcset="
                            {%- if image_url.width >= 165 -%}{{ image_url | image_url: width: 165 }} 165w,{%- endif -%}
                            {%- if image_url.width >= 330 -%}{{ image_url | image_url: width: 330 }} 330w,{%- endif -%}
                            {%- if image_url.width >= 535 -%}{{ image_url | image_url: width: 535 }} 535w,{%- endif -%}
                            {%- if image_url.width >= 750 -%}{{ image_url | image_url: width: 750 }} 750w,{%- endif -%}
                            {%- if image_url.width >= 1000 -%}{{ image_url | image_url: width: 1000 }} 1000w,{%- endif -%}
                            {%- if image_url.width >= 1500 -%}{{ image_url | image_url: width: 1500 }} 1500w,{%- endif -%}
                            {%- if image_url.width >= 3000 -%}{{ image_url | image_url: width: 3000 }} 3000w,{%- endif -%}
                            {{ image_url | image_url }} {{ image_url.width }}w
                          "
                          src="{{ image_url | image_url: width: 1500 }}"
                          sizes="(min-width: 750px) calc(100vw - 10rem),calc(100vw - 3rem)"
                          alt="{{ image_url.alt | escape }}"
                          height="{{ image_url.height }}"
                          width="{{ image_url.width }}"
                          loading="lazy"
                        >
                      {% else %}
                        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </div>

                    <span class="scrolling-cont-number">0{{ forloop.index }}</span>
    
                  </div>
                </div>
                <div class="scrolling-content--card w-100">
                  {% if block.settings.subheading != blank %}
                    <span class="sub-title text-base">{{ block.settings.subheading }}</span>
                  {% endif %}
                  {% if block.settings.heading != blank %}
                    <{{ block.settings.heading_seo }} class="scrolling-content--title {{ block.settings.heading_size }}">
                      {{- block.settings.heading -}}
                    </{{ block.settings.heading_seo }}>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <div class="description scrolling-content--description {{ block.settings.description_size }}">
                      {{ block.settings.description | newline_to_br }}
                    </div>
                  {% endif %}
                  {%- if block.settings.btn_text != blank and block.settings.btn_link != blank -%}
                    <div class="button-wrapper">
                      <a
                        href="{{ block.settings.btn_link }}"
                        class="{% if block.settings.button_style == 'text' %}underline--link{% else %}{{ settings.button_font }}-font button button-{{ block.settings.button_style }} button-{{ block.settings.btn_size }} hover-{{ block.settings.hover_effect }}{% endif %}"
                      >
                        <span class="button-text">{{ block.settings.btn_text }}</span>
                        {% if block.settings.button_style == 'text' %}
                          <span class="link-arrow">
                            <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentColor"/>
                            </svg>
                          </span>
                        {% endif %}
                      </a>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% when 'products' %}
              <div
                id="content-list-{{ block.id }}"
                class="scrolling-content--item product-card-list color-{{ block.settings.color_scheme }}"
                data-marker-content="content-{{block.id  }}"
                data-slide="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                <div class="mobile-scrolling-contnet desktop-hidden">
                  <div class="scrolling-content--img " id="content-{{block.id  }}">
                    <div class="scrolling-image">
                      {%- if block.settings.image != blank -%}
                        {% assign image_url = block.settings.image %}
                        <img
                          srcset="
                            {%- if image_url.width >= 165 -%}{{ image_url | image_url: width: 165 }} 165w,{%- endif -%}
                            {%- if image_url.width >= 330 -%}{{ image_url | image_url: width: 330 }} 330w,{%- endif -%}
                            {%- if image_url.width >= 535 -%}{{ image_url | image_url: width: 535 }} 535w,{%- endif -%}
                            {%- if image_url.width >= 750 -%}{{ image_url | image_url: width: 750 }} 750w,{%- endif -%}
                            {%- if image_url.width >= 1000 -%}{{ image_url | image_url: width: 1000 }} 1000w,{%- endif -%}
                            {%- if image_url.width >= 1500 -%}{{ image_url | image_url: width: 1500 }} 1500w,{%- endif -%}
                            {%- if image_url.width >= 3000 -%}{{ image_url | image_url: width: 3000 }} 3000w,{%- endif -%}
                            {{ image_url | image_url }} {{ image_url.width }}w
                          "
                          src="{{ image_url | image_url: width: 1500 }}"
                          sizes="(min-width: 750px) calc(100vw - 10rem),calc(100vw - 3rem)"
                          alt="{{ image_url.alt | escape }}"
                          height="{{ image_url.height }}"
                          width="{{ image_url.width }}"
                          loading="lazy"
                        >
                      {% else %}
                        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </div>

                    <span class="scrolling-cont-number">0{{ forloop.index }}</span>
                    <div class="scrolling-content-wrapper">
                      {% if block.settings.subheading != blank %}
                        <span class="sub-title text-base">{{ block.settings.subheading }}</span>
                      {% endif %}
                      {% if block.settings.heading != blank %}
                        <{{ block.settings.heading_seo }} class="scrolling-content--title {{ block.settings.heading_size }}">
                          {{- block.settings.heading -}}
                        </{{ block.settings.heading_seo }}>
                      {% endif %}
                    </div>
                  </div>
                </div>
                <div class="scrolling-content--card w-100">
                  <div class="grid grid-col-2">
                    {% if block.settings.product_list != blank %}
                      {% for product in block.settings.product_list %}
                        {% assign product_form_id = 'product-form-'
                          | append: block.id
                          | append: forloop.index
                          | append: '-'
                          | append: block.settings.collection.handle
                        %}
                        {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                        {%- assign placeholder_image = 'product-apparel-' | append: current -%}
                        {% render 'product-card',
                          product_card: product,
                          section: section,
                          product_form_id: product_form_id,
                          placeholder_image: placeholder_image,
                          content: false,
                          media_ratio: section.settings.image_size
                        %}
                      {% endfor %}
                    {% else %}
                      {% assign limit = 6 %}
                      {%- for i in (1..limit) -%}
                        {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                        {%- assign placeholder_image = 'product-apparel-' | append: current -%}
                        {% render 'product-card',
                          section: section,
                          placeholder_image: placeholder_image,
                          content: false,
                          media_ratio: section.settings.image_size
                        %}
                      {% endfor %}
                    {% endif %}
                  </div>
                </div>
              </div>
            {% when 'collections' %}
              <div
                id="content-list-{{ block.id }}"
                class="scrolling-content--item collection-list--grid color-{{ block.settings.color_scheme }}"
                data-marker-content="content-{{block.id  }}"
                data-slide="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                <div class="mobile-scrolling-contnet desktop-hidden">
                  <div class="scrolling-content--img swiper-slide" id="content-{{block.id  }}">
                    <div class="scrolling-image">
                      {%- if block.settings.image != blank -%}
                        {% assign image_url = block.settings.image %}
                        <img
                          srcset="
                            {%- if image_url.width >= 165 -%}{{ image_url | image_url: width: 165 }} 165w,{%- endif -%}
                            {%- if image_url.width >= 330 -%}{{ image_url | image_url: width: 330 }} 330w,{%- endif -%}
                            {%- if image_url.width >= 535 -%}{{ image_url | image_url: width: 535 }} 535w,{%- endif -%}
                            {%- if image_url.width >= 750 -%}{{ image_url | image_url: width: 750 }} 750w,{%- endif -%}
                            {%- if image_url.width >= 1000 -%}{{ image_url | image_url: width: 1000 }} 1000w,{%- endif -%}
                            {%- if image_url.width >= 1500 -%}{{ image_url | image_url: width: 1500 }} 1500w,{%- endif -%}
                            {%- if image_url.width >= 3000 -%}{{ image_url | image_url: width: 3000 }} 3000w,{%- endif -%}
                            {{ image_url | image_url }} {{ image_url.width }}w
                          "
                          src="{{ image_url | image_url: width: 1500 }}"
                          sizes="(min-width: 750px) calc(100vw - 10rem),calc(100vw - 3rem)"
                          alt="{{ image_url.alt | escape }}"
                          height="{{ image_url.height }}"
                          width="{{ image_url.width }}"
                          loading="lazy"
                        >
                      {% else %}
                        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </div>
                    <span class="scrolling-cont-number">0{{ forloop.index }}</span>
                    <div class="scrolling-content-wrapper">
                      {% if block.settings.subheading != blank %}
                        <span class="sub-title text-base">{{ block.settings.subheading }}</span>
                      {% endif %}
                      {% if block.settings.heading != blank %}
                        <{{ block.settings.heading_seo }} class="scrolling-content--title {{ block.settings.heading_size }}">
                          {{- block.settings.heading -}}
                        </{{ block.settings.heading_seo }}>
                      {% endif %}
                    </div>
                  </div>
                </div>
                <div class="scrolling-content--card w-100">
                  <div class="grid grid-col-2">
                    {% if block.settings.collection_list != blank %}
                      {% for collection in block.settings.collection_list %}
                        {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                        {% render 'collection-card',
                          collection_card: collection,
                          section: block,
                          image_ratio: block.settings.image_ratio,
                          placeholder_image: placeholder_image
                        %}
                      {% endfor %}
                    {% else %}
                      {% assign limit = 6 %}
                      {% for i in (1..limit) %}
                        {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                        {% render 'collection-card', section: section, placeholder_image: placeholder_image %}
                      {% endfor %}
                    {% endif %}
                  </div>
                </div>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</scrolling-content>
<style>
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --grid-item-per-row:{{- section.settings.mobile_item_per_row -}}
    }
  }
</style>
{% schema %}
{
  "name": "t:sections.scrolling_content.name",
  "class": "section-scrolling-content",
  "max_blocks": 8,
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:global.header.blocks.content"
    },
    {
      "type": "select",
      "id": "mobile_item_per_row",
      "label": "t:sections.scrolling_content.setting.mobile_item_per_row.label",
      "default": "2",
      "options": [
        {
          "label": "t:sections.scrolling_content.setting.mobile_item_per_row.options.1_column.label",
          "value": "1"
        },
        {
          "label": "t:sections.scrolling_content.setting.mobile_item_per_row.options.2_column.label",
          "value": "2"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "collections",
      "name": "t:sections.scrolling_content.blocks.collections.name",
      "settings": [
        {
          "type": "color_scheme",
          "id": "color_scheme",
         "label": "t:global.color_scheme.label", 
