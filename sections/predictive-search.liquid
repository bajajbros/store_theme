{%- if predictive_search.performed -%}
  <div class="predictive-search-results--details" data-result-wrapper>
    {%- if predictive_search.resources.products.size > 0
      or predictive_search.resources.articles.size > 0
      or predictive_search.resources.pages.size > 0
      or predictive_search.resources.queries.size > 0
      or predictive_search.resources.collections.size > 0
    -%}
      {% if predictive_search.resources.queries.size > 0 and settings.enable_queries %}
        <div class="predictive-popular-search">
          <span class="predictive-search-title">
            {{- 'templates.search.suggestions' | t -}}
          </span>
          <ul class="search-popular">
            {%- for query in predictive_search.resources.queries -%}
              <li>
                <a
                  class="search-popular-link"
                  href="{{ query.url }}"
                  aria-label="{{ query.text }}"
                >
                  {{- query.styled_text -}}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {% endif %}
      {%- if predictive_search.resources.products.size > 0
        or predictive_search.resources.articles.size > 0
        or predictive_search.resources.pages.size > 0
        or predictive_search.resources.collections.size > 0
      -%}
        <predictive-search-tab class="predictive-search-tabs">
          {% if predictive_search.resources.products.size > 0 %}
            <button
              class="predictive-search-tab"
              data-type-target="products"
              data-tab="#productsTab"

              tabindex="0"
            >
              <span class="predictive-search-tab-title">{{ 'general.search.products' | t}}</span>
            </button>
          {% endif %}
          {% if predictive_search.resources.collections.size > 0 and settings.enable_collections %}
            <button
              class="predictive-search-tab"
              data-type-target="collections"
              data-tab="#collectionsTab"
              tabindex="0"
            >
              <span class="predictive-search-tab-title">{{ 'general.search.collections' | t }}</span>
            </button>
          {% endif %}
          {% if predictive_search.resources.articles.size > 0 and settings.enable_article %}
            <button class="predictive-search-tab" data-tab="#articlesTab" data-type-target="articles" tabindex="0">
              <span class="predictive-search-tab-title">{{'general.search.blog_post' | t}}</span>
            </button>
          {% endif %}
          {% if predictive_search.resources.pages.size > 0 and settings.enable_pages %}
            <button class="predictive-search-tab" data-tab="#pagesTab" data-type-target="articles" tabindex="0">
              <span class="predictive-search-tab-title">{{ 'general.search.pages' | t}}</span>
            </button>
          {% endif %}
        </predictive-search-tab>
        <div class="predictive-search-content">
          {% if predictive_search.resources.products.size > 0 %}
            <div id="productsTab" class="predictive-search-item" style="display: none;">
              <div class="predictive-search-grid">
                {% for product in predictive_search.resources.products %}
                  {% assign product_form_id = 'product-form-' | append: section.id | append: forloop.index %}
                  {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                  {%- assign placeholder_image = 'product-apparel-' | append: current -%}
                  {% render 'product-card',
                    product_card: product,
                    product_form_id: product_form_id,
                    placeholder_image: placeholder_image,
                    search: true
                  %}
                {% endfor %}
              </div>
            </div>
          {% endif %}
          {% if predictive_search.resources.collections.size > 0 and settings.enable_collections %}
            <div id="collectionsTab" class="predictive-search-item" style="display: none;">
              <div class="predictive-search-grid">
                {% for card_collection in predictive_search.resources.collections %}
                  {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                  {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                  {% render 'collection-card', collection_card: card_collection, placeholder_image: placeholder_image %}
                {% endfor %}
              </div>
            </div>
          {% endif %}
          {% if predictive_search.resources.articles.size > 0 and settings.enable_article %}
            <div id="articlesTab" class="predictive-search-item" style="display: none;">
              <div class="predictive-search-blog">
                {%- for article in predictive_search.resources.articles -%}
                  {% assign placeholder_image_index = forloop.index0 | modulo: 3 | plus: 1 %}
                  {% assign placeholder_image = 'blog-apparel-' | append: placeholder_image_index %}
                  {% render 'blog-post', article: article, layoutStyle: 'grid', placeholder_image: placeholder_image %}
                {% endfor %}
              </div>
            </div>
          {% endif %}
          {% if predictive_search.resources.pages.size > 0 and settings.enable_pages %}
            <div id="pagesTab" class="predictive-search-item" style="display: none;">
              <ul class="search-pages">
                {%- for page in predictive_search.resources.pages -%}
                  <li>
                    <a href="{{ page.url }}" aria-label="{{ page.title }}">
                      <svg width="12" height="14" viewBox="0 0 12 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M0.666016 0.333008H6.67722L11.3327 5.00549V13.6663H0.666016V0.333008ZM1.99935 1.66634V12.333H9.99935V6.33301H5.33268V1.66634H1.99935ZM6.66602 2.21081L9.44468 4.99967H6.66602V2.21081Z" fill="currentcolor"/>
                      </svg>
                      <span>{{- page.title -}}</span>
                      <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentcolor"/>
                      </svg>
                    </a>
                  </li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% else %}
      <div class="predictive-search__no-results text-align-center">
        <svg class="icon" width="69" height="57" viewBox="0 0 69 57" fill="none" xmlns="http://www.w3.org/2000/svg">
