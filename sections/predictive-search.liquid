          <path d="M42 23.5C42 25.5 38 25.5 38 23.5C38 21.5 42 21.5 42 23.5Z" fill="currentcolor"/>
          <path d="M30 23.5C30 25.5 26 25.5 26 23.5C26 21.5 30 21.5 30 23.5Z" fill="currentcolor"/>
        </svg>
        <p class="h5 body-font">
          {{  'templates.search.no_results_at_html' | t: terms: predictive_search.terms }}
        </p>
        <p class="text-base">{{ 'templates.search.spell_check' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="button button-md {{ settings.button_font }}-font"
          >{{ 'templates.search.continue_shopping' | t }}</a
        >
      </div>
    {% endif %}
  </div>
{% endif %}
