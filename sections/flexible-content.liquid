{{ 'flexible.css' | asset_url | stylesheet_tag }}
<div class="flexible-content-section color-{{ section.settings.color_scheme }} section-gap">
  <div class="page--width">

    {% if section.settings.heading != blank or section.settings.description != blank %}
    <heading-main class="main-heading text-align-{{ section.settings.text_alignment }}">
      {% if section.settings.heading != blank %}
      <{{ section.settings.heading_seo }} class="section-title {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </{{ section.settings.heading_seo }}>
      {% endif %}

      {% if section.settings.description != blank %}
      <div class="section-description {{ section.settings.description_size }}">
        {{ section.settings.description | newline_to_br }}
      </div>
      {% endif %}
    </heading-main>
    {% endif %}


    <div class="relative">

            <slider-component class="swiper center-scale-slider" data-settings='
                {
                  "loop": true,
                  "speed": 1000,
                  "slidesPerGroup": 1,
                  "centeredSlides": true,
                  "spaceBetween": "{{ section.settings.column_gap_mobile }}px",
                  "slidesPerView": 1.3,
                  "navigation": {
                    "nextEl": ".swiper-button-next-{{ section.id }}",
                    "prevEl": ".swiper-button-prev-{{ section.id }}"
                  },
                  "breakpoints": {
                    
                    "768": {
                      "slidesPerView": 3,
                      "spaceBetween": "{{ section.settings.column_gap }}px"
                    },
                    "1280": {
                      "slidesPerView": 5,
                      "spaceBetween": "{{ section.settings.column_gap }}px"
                    }
                  }
                }
              ' tabindex="0">

           <div class="{% if section.settings.show_product_on_active %}show_product_on_active{% endif %} flexible_card product-card-list swiper-wrapper">
 

            {% for block in section.blocks limit: section.settings.products_to_show %}
            {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
            {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
            {% render 'flexible-card',
            block: block,
            section: section,
            slider: true
            placeholder_image: placeholder_image
            %}
            {% endfor %}

            </div>
          </slider-component>

          <div
            class="flexible-slider-arrow slider-controls {% if section.settings.number_item<=4 and section.settings.products_to_show <=4 %}desktop-hidden{% endif %}">
            <div class="swiper-button-prev swiper-button swiper-button-prev-{{ section.id }}"></div>
            <div class="swiper-button-next swiper-button swiper-button-next-{{ section.id }}"></div>
          </div>
    
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }}.shopify-section {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
  }
</style>
