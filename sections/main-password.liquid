<div class="password-section color-{{ section.settings.color_scheme }}">

  {% capture logo %}
      <div class="header-item site--logo password-logo-left">
        <a class="logo-image--wrapper" href="{{ routes.root_url }}">
          {%- if settings.logo != blank -%}
            {% render 'logo' %}
          {% else %}
            <span class="h4">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>
    {% endcapture %}
  <div class="password-main">
    <div class="page--width">
      <div class="password-header">
          {{ logo }}
        <a href="#password" data-paswordpopup-head class="underline">
          {{- 'general.password_page.login_password_button' | t -}}
        </a>
      </div> 
      <div class="password-body">
        <div class="password-content">
          {% if section.settings.heading != blank %}
            <{{ section.settings.heading_seo }} class="title {{ section.settings.heading_size }}">
              {{- section.settings.heading -}}
            </{{ section.settings.heading_seo }}>
          {% endif %}
          {% if section.settings.description != blank %}
            <div class="password-text {{ section.settings.description_size }} rte">
              {{ section.settings.description }}
            </div>
          {% endif %}
          <div class="newsletter-password-form">
            {% form 'customer', id: 'password_form', class: 'newsletter-form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <input type="hidden" name="form_type" value="customer">
              <input type="hidden" name="utf8" value="✓">
              {%- if form.posted_successfully? -%}
                {% assign form = true %}
                <div id="newsletter-success--{{ section.id }}" role="alert" class="alert alert-success" tabindex="-1">
                  {{- 'newsletter.success' | t -}}
                </div>
              {%- endif -%}
              {%- if form.errors -%}
                <div
                  id="newsletter-error--{{ section.id }}"
                  role="alert"
                  class="alert alert-warning"
                  tabindex="-1"
                >
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </div>
              {%- endif -%}

              <div class="newsletter--form">
                <div class="form-control">
                  <label class="hidden" for="passwordEmail">{{ 'newsletter.label' | t }}</label>
                  <input
                    id="passwordEmail"
                    type="email"
                    name="contact[email]"
                    class="input"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="Newsletter-error--{{ section.id }}"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="Newsletter-success--{{ section.id }}"
                    {% endif %}
                    pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)*[a-zA-Z]{2,}))$"
                    placeholder="{{'customer.recover_password.enter_email' | t}}"
                    required
                  >
                </div>
                <button
                  type="submit"
                  class="button button-md w-100 {{ settings.button_font }}-font"
                  name="commit"
                  id="Subscribe"
                  aria-label="Subscribe"
                >
                  {{ 'newsletter.button_label' | t }}
                </button>
              </div>
            {% endform %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <password-popup-element id="password" class="password-popup" data-popup-content>
    <div class="password-popup-inner">
      <a href="#" class="close-popup" aria-label="Close" data-popup-close>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
              d="M17.998 0.999967C18.2742 0.723825 18.7219 0.723825 18.998 0.999967C19.2742 1.27611 19.2742 1.72382 18.998 1.99997L1.99802 19C1.72188 19.2761 1.27417 19.2761 0.998024 19C0.721882 18.7238 0.721882 18.2761 0.998024 18L17.998 0.999967Z"
              fill="currentColor"
          ></path>
          <path
              d="M0.5 1.5C0.223858 1.22386 0.223858 0.776142 0.5 0.5C0.776142 0.223858 1.22386 0.223858 1.5 0.5L19.5 18.5C19.7761 18.7761 19.7761 19.2239 19.5 19.5C19.2239 19.7761 18.7761 19.7761 18.5 19.5L0.5 1.5Z"
              fill="currentColor"
          ></path>
        </svg>
      </a>

      {% if section.settings.popup_heading != blank %}
        <h4>{{ section.settings.popup_heading }}</h4>
      {% endif %}
      {%- form 'storefront_password', class: 'password-form' -%}
        <input type="hidden" name="form_type" value="storefront_password">
        <input type="hidden" name="utf8" value="✓">
        {% if form.errors %}
          <p id="passwordError" class="form-error ">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="form-control">
          <label class="hidden" for="Password">{{- 'general.password_page.login_form_password_label' | t -}}</label>
          <input
            type="password"
            name="password"
            id="Password"
            class="input"
            autocomplete="current-password"
            placeholder="{{'customer.activate_account.password' | t}}"
          >
        </div>
        {%- if form.errors -%}
          <div id="Newsletter-error--{{ section.id }}" class="form-message-wrapper error" tabindex="-1">
            <div class="error-text">
              {{ 'general.password_page.login_form_error' | t -}}
            </div>
          </div>
        {%- endif -%}
        <button name="commit" class="button button-md w-100 {{ settings.button_font }}-font">
          {{ 'general.password_page.login_form_submit' | t }}
        </button>
      {% endform %}

      <div class="text-sm">
        <span>{{ 'general.password_page.store_owner'| t }}<a href="{{ routes.account_login_url }}" class="underline">{{ 'general.password_page.login_here' | t }}</a></span>
      </div>
    </div>
  </password-popup-element>
</div>

{% schema %}
{
  "name": "t:sections.main-password.name",
  "tag": "section",
  "class": "password-section",
  "settings": [
    {
        "type": "color_scheme",
        "id":"color_scheme",
        "label": "t:global.color_scheme.label", 
        "default":"scheme-1"
    },
     {
          "type":"inline_richtext",
          "id":"heading",
          "label": "t:global.general_label.heading.label",
          "default":"Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "default": "h2",
           "label": "t:global.heading_size.label",
            "options": [
              {
                "value": "h1",
                "label": "t:global.heading_size.options.h1.label"
              },
              {
                "value": "h2",
              "label": "t:global.heading_size.options.h2.label"
              },
              {
                "value": "h3",
              "label": "t:global.heading_size.options.h3.label"
              },
              {
                "value": "h4",
              "label": "t:global.heading_size.options.h4.label"
              },
              {
                "value": "h5",
                "label": "t:global.heading_size.options.h5.label"
              },
              {
                "value": "h6",
              "label": "t:global.heading_size.options.h6.label"
              }
            ]
        },
        {
          "type": "select",
          "id": "heading_seo",
          "default": "h2",
          "label": "t:global.heading_seo.label",
      "info": "t:global.heading_seo.info",
      "options": [
         {
            "value": "h1",
            "label": "t:global.heading_seo.options.h1.label"
          },
          {
            "value": "h2",
           "label": "t:global.heading_seo.options.h2.label"
          },
          {
            "value": "h3",
           "label": "t:global.heading_seo.options.h3.label"
          },
          {
            "value": "h4",
          "label": "t:global.heading_seo.options.h4.label"
          },
          {
            "value": "h5",
            "label": "t:global.heading_seo.options.h5.label"
          },
          {
            "value": "h6",
          "label": "t:global.heading_seo.options.h6.label"
          }
        ]
        },
          {
          "type": "richtext",
          "id": "description",
          "label": "t:global.general_label.description.label",
          "default":"<p>Tell your brand's story through images</p>"
        },
        {
          "type": "select",
          "id": "description_size",
          "default": "text-base",
           "label": "t:global.description_size.label",
          "options": [
            {
              "value": "text-xl",
              "label": "t:global.description_size.options.x-large.label"
            },
            {
              "value": "text-lg",
              "label": "t:global.description_size.options.large.label"
            },
            {
              "value": "text-base",
              "label": "t:global.description_size.options.medium.label"
            },
            {
              "value": "text-sm",
              "label": "t:global.description_size.options.small.label"
            },
            {
              "value": "text-xs",
              "label": "t:global.description_size.options.x-small.label"

            }
          ]
      },
     {
        "type": "header",
        "content": "t:global.header.popup.content"
    },
    {
      "type": "text",
      "id": "popup_heading",
     "label": "t:global.general_label.heading.label",
      "default": "Enter Password"
    }
  ]
}
{% endschema %}
