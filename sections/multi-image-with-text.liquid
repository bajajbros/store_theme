{{ 'multi-image-with-text.css' | asset_url | stylesheet_tag }}
<div class="multi-image-with--text-section section-gap color-{{ section.settings.color_scheme }}">
  <div class="page--width">
    <div class="multi-image-with--text-wrapper {% if section.settings.image_second != blank %}secondary--image-enabled{% endif %}">
      <div class="multi-image-with--text-item multi-image-with--text-img">
        {% if section.settings.image_first != null %}
          {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
          {%- capture sizes -%}
                  (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
              {%- endcapture -%}
          {{ section.settings.image_first | image_url: width: 1500 | image_tag: sizes: sizes, widths: widths }}
        {% else %}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      {% if section.settings.image_second != blank %}
        <div class="multi-image-with--text-item multi-image-with--text-img secondary--image">
          {% if section.settings.image_second != null %}
            {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
            {%- capture sizes -%}
                  (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
            {%- endcapture -%}
            {{ section.settings.image_second | image_url: width: 1500 | image_tag: sizes: sizes, widths: widths }}
          {% endif %}
        </div>
      {% endif %}
      {% if section.blocks.size > 0 %}
        <div class="multi-image-with--text-item multi-image-with--text-content text-align-{{ section.settings.content_alignment }}">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'heading' %}
                {%- if block.settings.heading != blank -%}
                  <{{ block.settings.heading_seo }} class="{{ block.settings.heading_size }}">
                    {{- block.settings.heading -}}
                  </{{ block.settings.heading_seo }}>
                {% endif %}
              {% when 'description' %}
                {%- if block.settings.description != blank -%}
                  <div class="description {{ block.settings.description_size }}">
                    {{ block.settings.description | newline_to_br }}
                  </div>
                {% endif %}
              {% when 'button' %}
                {%- if block.settings.btn_text != blank and block.settings.btn_link != blank -%}
                  <a
                    href="{{ block.settings.btn_link }}"
                    class="{% if block.settings.button_style == 'text' %}underline--link{% else %}{{ settings.button_font }}-font button button-{{ block.settings.button_style }} button-{{ block.settings.btn_size }} hover-{{ block.settings.hover_effect }}{% endif %}"
                  >
                    <span class="button-text">{{ block.settings.btn_text }}</span>
                    {% if block.settings.button_style == 'text' %}
                      <span class="link-arrow">
                        <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentColor"/>
                        </svg>
                      </span>
                    {% endif %}
                  </a>
                {% endif %}
            {% endcase %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;
    --grid-gap:{{ section.settings.column_gap }}px;

  }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
      --grid-gap:{{ section.settings.column_gap_mobile }}px;
    }

  }
</style>

