{{ 'collection-carousel.css' | asset_url | stylesheet_tag }}
<section class="collection-carousel-section section-gap color-{{ section.settings.color_scheme }}">
  <div class="page--width">
    {% if section.settings.heading != blank or section.settings.description != blank %}
      <heading-main class="main-heading text-align-{{ section.settings.content_alignment }}">
        {% if section.settings.heading != blank %}
          <{{ section.settings.heading_seo }} class="section-title body-font {{ section.settings.heading_size }}">
            {% if section.settings.heading != blank -%}
              {{- section.settings.heading -}}
            {% endif %}
          </{{ section.settings.heading_seo }}>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="section-description {{ section.settings.description_size }}">
            {{ section.settings.description | newline_to_br }}
          </div>
        {% endif %}
      </heading-main>
    {% endif %}
  </div>
  <div class="collection-carousel--wrapper">
    <slider-component
      class="swiper collection-carousel-slider"
      data-settings='
        {
          "loop": true,
          "slidesPerView": 1.3,
          "centeredSlides": true,
          "slidesPerGroup": 1,
          "speed": 600,
          "spaceBetween": "{{ section.settings.column_gap_mobile }}",
          "navigation": {
            "nextEl": ".swiper-button-next-{{ section.id }}",
            "prevEl": ".swiper-button-prev-{{ section.id }}"
          },
          "breakpoints": {
            "768": {
              "slidesPerView": 1.3,
              "slidesPerGroup": 1,
              "spaceBetween": "{{ section.settings.column_gap }}"
            },
            "1081": {
              "slidesPerView": 2.3,
              "slidesPerGroup": 1,
              "spaceBetween": "{{ section.settings.column_gap }}"
            }
          }
        }
      '
      tabindex="0"
    >

      <div class="swiper-wrapper">
        {% capture collection_carousel %}
           {%- for block in section.blocks -%}
          {% liquid
            assign collection = block.settings.collection
            assign image_url = ''
            if block.settings.image != blank
              assign image_url = block.settings.image
            elsif collection.featured_image
              assign image_url = collection.featured_image
            endif

            assign image_ratio = section.settings.image_ratio
            if image_ratio == 'landscape'
              assign media_ratio = 75
            elsif image_ratio == 'square'
              assign media_ratio = 100
            elsif image_ratio == 'portrait'
              assign media_ratio = 125
            else
              if collection.featured_image != blank
                assign media_ratio = 1 | divided_by: collection.featured_image.aspect_ratio | times: 100
              else
                assign media_ratio = 100
              endif
            endif
          %}
          <div class="swiper-slide" {{ block.shopify_attributes }} role="img">
            <div class="collection-carousel-item color-{{ block.settings.color_scheme }}">
              <div class="collection-carousel-img--wrapper">
                <div class="media-ratio" style="--media-ratio:{{ media_ratio }}%">
                  {% if image_url != blank %}
                    <img
                      srcset="
                        {%- if image_url.width >= 165 -%}{{ image_url | image_url: width: 165 }} 165w,{%- endif -%}
                        {%- if image_url.width >= 330 -%}{{ image_url | image_url: width: 330 }} 330w,{%- endif -%}
                        {%- if image_url.width >= 535 -%}{{ image_url | image_url: width: 535 }} 535w,{%- endif -%}
                        {%- if image_url.width >= 750 -%}{{ image_url | image_url: width: 750 }} 750w,{%- endif -%}
                        {%- if image_url.width >= 1000 -%}{{ image_url | image_url: width: 1000 }} 1000w,{%- endif -%}
                        {%- if image_url.width >= 1500 -%}{{ image_url | image_url: width: 1500 }} 1500w,{%- endif -%}
                        {%- if image_url.width >= 3000 -%}{{ image_url | image_url: width: 3000 }} 3000w,{%- endif -%}
                        {{ image_url | image_url }} {{ image_url.width }}w
                      "
                      src="{{ image_url | image_url: width: 1500 }}"
                      sizes="calc(100vw - 3rem)"
                      alt="{{ image_url.alt | escape }}"
                      height="{{ image_url.height }}"
                      width="{{ image_url.width }}"
                      loading="lazy"
                    >

                  {% else %}
                    {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                    {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                    {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
              </div>
              <collection-carousel-info class="collection-carousel-cont content-overlay text-align-center">
                <div class="collection-carousel--content ">
                  {% if block.settings.subheading != blank %}
                    <div class="badge badge-sale">{{ block.settings.subheading }}</div>
                  {% endif %}
                  {% if collection != blank or block.settings.heading != blank %}
                    <{{ block.settings.heading_seo }} class="collection-title {{ block.settings.heading_size }}">
                      {% if block.settings.heading != blank -%}
                        {{- block.settings.heading -}}
                      {%- elsif collection != blank -%}
                        {{- collection.title -}}
                      {% else %}
                        {{ 'onboarding.collection_title' | t }}
                      {%- endif %}
                    </{{ block.settings.heading_seo }}>
                  {% endif %}
                  {%- if block.settings.btn_text != blank and collection != blank -%}
                    <div class="collection-button-wrapper">
                      <a
                        href="{{ collection.url }}"
                        class="{% if block.settings.button_style == 'text' %}underline--link{% else %} {{ settings.button_font }}-font button button-{{ block.settings.button_style }} button-{{ block.settings.btn_size }} hover-{{ block.settings.hover_effect }}{% endif %}"
                      >
                        <span class="button-text">{{ block.settings.btn_text }}</span>
                        {% if block.settings.button_style == 'text' %}
                          <span class="link-arrow">
                            <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentColor"/>
                            </svg>
                          </span>
                        {% endif %}
                      </a>
                    </div>
                  {% endif %}
                  {% if block.settings.product_list != blank %}
                    <div class="products--wrapper flex collection-carousel--product justify-content-center">
                      {%- for product in block.settings.product_list -%}
                        {% assign product_form_id = 'product-form-'
                          | append: section.id
                          | append: forloop.index
                          | append: '-'
                          | append: collection.handle
                        %}
                        {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                        {%- assign placeholder_image = 'product-apparel-' | append: current -%}
                        {% render 'product-card',
                          product_card: product,
                          section: section,
                          content: false,
                          product_form_id: product_form_id,
                          placeholder_image: placeholder_image
                        %}
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
              </collection-carousel-info>
            </div>
          </div>
        {% endfor %}
        {% endcapture %}
        {% if section.blocks.size == 2 or section.blocks.size == 3 %}
          {%- for i in (1..2) -%}
            {{ collection_carousel }}
          {% endfor %}
        {% else %}
          {{ collection_carousel }}
        {% endif %}
      </div>
      <div class="swiper-button-prev swiper-button swiper-button-prev-{{ section.id }}"></div>
      <div class="swiper-button-next swiper-button swiper-button-next-{{ section.id }}"></div>
    </slider-component>
  </div>
</section>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;

  }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;

    }

  }
</style>
