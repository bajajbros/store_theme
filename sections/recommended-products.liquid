<div class="recommended-products  color-{{ section.settings.color_scheme }} section-gap">
  {{  }}
  <div class="page--width">
    <recommendations-product
      class="block relative"
      data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ section.settings.product.id | default: product.id }}&limit={{ section.settings.products_count }}&intent={{section.settings.recommendation_type}}"
      recommendations-product
    >
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        {% if section.settings.heading != blank %}
          <heading-main class="main-heading">
            {% if section.settings.heading != blank or collection != blank and section.settings.show_collection_title %}
              <{{ section.settings.heading_seo }} class="{{ section.settings.heading_size }}">
                {{- section.settings.heading -}}
              </{{ section.settings.heading_seo }}>
            {% endif %}
          </heading-main>
        {% endif %}
        <div class="related-products-wrapper">
          <slider-component
            class="swiper"
            data-settings='
                {
                "loop": true,
                "slidesPerView": {{ section.settings.mobile_item_per_row }},
                "speed":600,
                "centeredSlides":false,
                "spaceBetween":"{{ section.settings.column_gap_mobile }}px",
                "navigation": {
                  "nextEl": ".swiper-button-next-{{ section.id }}",
                  "prevEl": ".swiper-button-prev-{{ section.id }}"
                },

              "a11y": {
                "enabled": true
              },
              "breakpoints": {
                "600": {
                  "slidesPerView": {{ section.settings.column_per_row }},
                  "spaceBetween":"{{ section.settings.column_gap }}px"
                }
              }
              }
            '
          >
            <div class="product-card-list swiper-wrapper">
              {%- for product in recommendations.products limit: section.settings.products_count -%}
                {% assign product_form_id = 'product-form-'
                  | append: section.id
                  | append: forloop.index
                  | append: '-'
                  | append: collection.handle
                %}
                {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                {%- assign placeholder_image = 'product-apparel-' | append: current -%}
                {% render 'product-card',
                  product_card: product,
                  section: section,
                  slider: true,
                  product_form_id: product_form_id,
                  media_ratio: section.settings.image_size,
                  placeholder_image: placeholder_image
                %}
              {% endfor %}
            </div>
          </slider-component>
          <div class="slider-controls {% if section.settings.column_per_row<=4 and section.settings.products_count <=4 or recommendations.products.size<= 4 %}desktop-hidden{% endif %}">
            <div class="swiper-button-prev swiper-button swiper-button-prev-{{ section.id }}"></div>
            <div class="swiper-button-next swiper-button swiper-button-next-{{ section.id }}"></div>
          </div>
        </div>
      {% endif %}
    </recommendations-product>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --section-gap-top:{{ section.settings.top_space_desktop }}px;
    --section-gap-bottom:{{ section.settings.bottom_space_desktop }}px;
    --grid-gap:{{ section.settings.column_gap }}px;
  }

    #shopify-section-{{ section.id }}.shopify-section .product-card-list {
      --grid-col-item: {{ section.settings.column_per_row }};
    }

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --section-gap-top:{{ section.settings.top_space_mobile }}px;
      --section-gap-bottom:{{ section.settings.bottom_space_mobile }}px;
      --grid-gap:{{ section.settings.column_gap_mobile }}px;
    }
    #shopify-section-{{ section.id }}.shopify-section .product-card-list {
      --grid-col-item: {{ section.settings.mobile_item_per_row }};
    }
  }
</style>
{% schema %}
{
  "name": "t:sections.recommended-products.name",
    "class": "section-recommended-products ",
    "tag": "section",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
      "settings": [
         {
        "type": "color_scheme",
        "id":"color_scheme",
         "label": "t:global.color_scheme.label", 
        "default":"scheme-1"
    },
     {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "select",
      "id": "recommendation_type",
      "label": "Type",
      "options": [
        {
          "value": "related",
          "label": "Related"
        },
        {
          "value": "complementary",
          "label": "Complementary"
        }
      ],
      "default": "related"
    },
    {
        "type":"inline_richtext",
        "id":"heading",
          "label": "t:global.general_label.heading.label",
        "default":"Recommended products"
      },
      {
        "type": "select",
        "id": "heading_size",
        "default": "h3",
         "label": "t:global.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:global.heading_size.options.h1.label"
        },
        {
          "value": "h2",
         "label": "t:global.heading_size.options.h2.label"
        },
        {
          "value": "h3",
         "label": "t:global.heading_size.options.h3.label"
        },
        {
          "value": "h4",
        "label": "t:global.heading_size.options.h4.label"
        },
        {
          "value": "h5",
          "label": "t:global.heading_size.options.h5.label"
        },
        {
          "value": "h6",
        "label": "t:global.heading_size.options.h6.label"
        }
      ]
      },
      {
        "type": "select",
        "id": "heading_seo",
        "default": "h2",
        "label": "t:global.heading_seo.label",
      "info": "t:global.heading_seo.info",
      "options": [
         {
            "value": "h1",
            "label": "t:global.heading_seo.options.h1.label"
          },
          {
            "value": "h2",
           "label": "t:global.heading_seo.options.h2.label"
          },
          {
            "value": "h3",
           "label": "t:global.heading_seo.options.h3.label"
          },
          {
            "value": "h4",
          "label": "t:global.heading_seo.options.h4.label"
          },
          {
            "value": "h5",
            "label": "t:global.heading_seo.options.h5.label"
          },
          {
            "value": "h6",
          "label": "t:global.heading_seo.options.h6.label"
          }
        ]
      },
        {
    "type": "select",
    "id": "image_size",
    "default": "adapt",
   "label": "t:sections.recommended-products.settings.image_size.label",
  "options": [
    {
      "value": "adapt",
      "label": "t:sections.recommended-products.settings.image_size.options.adapt.label"
    },
    {
      "value": "landscape",
      "label": "t:sections.recommended-products.settings.image_size.options.landscape.label"
    },
    {
      "value": "portrait",
      "label": "t:sections.recommended-products.settings.image_size.options.portrait.label"
    },
    {
      "value": "square",
      "label": "t:sections.recommended-products.settings.image_size.options.square.label"
    }
  ]
    },
        {
      "type": "range",
      "id": "products_count",
      "min": 4,
      "max": 12,
      "step": 1,
    "label": "t:sections.recommended-products.settings.products_count.label",
      "default": 8
    },
        {
      "type": "range",
      "id": "column_per_row",
      "min": 2,
      "max": 6, 
      "step": 1,
      "default": 4,
     "label": "t:sections.recommended-products.settings.products_count.label",
    },
      {
      "type": "select",
      "id": "mobile_item_per_row",
      "label": "t:sections.recommended-products.settings.mobile_item_per_row.label",
      "default": "2",
      "options": [
        {
          "label": "t:sections.recommended-products.settings.mobile_item_per_row.options.1.label",
          "value": "1"
        },
        {
          "label": "t:sections.recommended-products.settings.mobile_item_per_row.options.2.label",
          "value": "2"
        }
      ]
    },
    {
      "type": "range",
      "id":"column_gap",
      "label":"t:global.general_label.column_gap.label",
      "min":0,
      "max":50,
      "default":20,
      "step": 1,
      "unit": "px"
