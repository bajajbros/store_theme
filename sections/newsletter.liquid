              "label": "t:global.description_size.options.medium.label"
            },
            {
              "value": "text-sm",
              "label": "t:global.description_size.options.small.label"
            },
            {
              "value": "text-xs",
              "label": "t:global.description_size.options.x-small.label"

            }
          ]
  },
   {
          "type": "select",
          "id": "content_position",
          "label": "t:sections.newsletter.settings.content_position.label",
          "default": "center",
          "options": [
            {
              "value": "left",
              "label": "t:sections.newsletter.settings.content_position.options.left.label"
            },
            {
              "value": "center",
              "label": "t:sections.newsletter.settings.content_position.options.center.label"
            },
            {
              "value": "right",
