<!doctype html>
<html class="js full-height" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    {{ content_for_header }}
    {% render 'theme-style' %}
    {% render 'theme-script' %}
    {%- unless settings.type_body_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_body_font | font_url }}"
        type="font/woff2"
        crossorigin
      >
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_header_font | font_url }}"
        type="font/woff2"
        crossorigin
      >
    {%- endunless -%}
    <script>
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
  </head>
  <body class="password gradient">
    <a class="skip-to-content-link button visually-hidden hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>
    <main id="MainContent" class="password-main">
      {{ content_for_layout }}
    </main>
    <footer></footer>
    <ul hidden>
      <li id="a11y-new-window-message">{{ 'accessibility.link_messages.new_window' | t }}</li>
    </ul>

    <script>
            document.addEventListener('DOMContentLoaded', function () {
              if(document.querySelector("#passwordError")){
                document.querySelector("#password").classList.add("is-visible");
                document.body.classList.add("overflow-hidden")
              }

            })

            class PasswordPopup extends HTMLElement {
        constructor() {
          super();
        }

        connectedCallback() {
          this.addEventListeners();
        }

        addEventListeners() {
          const openButton = document.querySelector('[data-paswordpopup-head]');
          const content = this;
          const closeButton = this.querySelector('[data-popup-close]');

          if (openButton) {
            openButton.addEventListener('click', (e) => this.openPopup(e));
          }

          if (closeButton) {
            closeButton.addEventListener('click', (e) => this.closePopup(e));
          }
        }

        openPopup(e) {
          e.preventDefault();
          this.classList.add('is-visible');
          document.querySelector("body").classList.add("overflow-hidden");

        }

        closePopup(e) {
          e.preventDefault();
           document.querySelector("body").classList.remove("overflow-hidden");
          this.classList.remove('is-visible');

        }
      }

      customElements.define('password-popup-element', PasswordPopup);
    </script>
  </body>
</html>
