{% if section.settings.menu != blank %}
  <mobile-hamburger-menu class="mobile-menu-slide--wrapper">
    <a href="#drawerMobileMenu" class="toggle-btn" data-hamburger-mobile aria-label="humburger icon">
      <svg class="hamburger" width="24" height="18" viewBox="0 0 24 18" fill="none">
        <path class="line-1" d="M0 0H20V2H0V0Z" fill="currentColor" />
        <path class="line-2" d="M0 8H24V10H0V8Z" fill="currentColor" />
        <path class="line-3" d="M0 16H14V18H0V16Z" fill="currentColor" />
      </svg>
    </a>
    <drawer-mobile-menu class="mobile-menu-slide" id="drawerMobileMenu" data-mobile-drawer-content role="dialog">
      <div class="drawer-mobile-action">
        <header-drawer class="drawer-toggle" data-drawer-head>
          <button class="drawer-toggle-button" aria-label="hamburger menu">
            <svg
              class="svg--menu"
              xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              x="0px"
              y="0px"
              width="16px"
              height="14px"
              viewBox="0 0 16 14"
              style="enable-background:new 0 0 16 14;"
              xml:space="preserve"
            >
              <line x1="1" y1="1" x2="15" y2="1"></line><line x1="1" y1="7" x2="15" y2="7"></line><line x1="1" y1="13" x2="15" y2="13"></line>
            </svg>
            <svg
              class="svg--close"
              xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              x="0px"
              y="0px"
              width="13px"
              height="13px"
              viewBox="0 0 13 13"
              style="enable-background:new 0 0 13 13;"
              xml:space="preserve"
            >
              <line x1="1.3" y1="11.7" x2="11.7" y2="1.3"></line><line x1="11.7" y1="11.7" x2="1.3" y2="1.3"></line>
            </svg>
            <Span> MORE </Span>
          </button>
        </header-drawer>
        <a href="#" class="toggle-btn" data-mobile-menu-close="#drawerMobileMenu" aria-label="close">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 1L1 21M1 1L21 21" stroke="currentColor" stroke-linecap="square" stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
      <div id="mobileMenuSlide" class="drawer-mobile-menu" data-mobile-menu>
        <div class="mobile-menu-slide-box">
          <ul class="mobile-menu-slide-nav">
            {%- for link in linklists[section.settings.menu].links -%}
              {% liquid
                assign mega_menu_status = false
                assign link_title = link.title | downcase
                for block in section.blocks
                  assign mega_menu_title = block.settings.menu_label | downcase
                  if mega_menu_title == link_title
                    capture collections_content
                      if block.settings.collection_list.count > 0
                        render 'block-menu-item', type: 'collections_content', block: block
                      endif
                    endcapture
                    capture custom_content
                      for i in (1..5)
                        assign image_setting = 'content_image_' | append: i
                        assign heading_setting = 'content_heading_' | append: i
                        assign subheading_setting = 'content_subheading_' | append: i
                        assign link_setting = 'content_link_' | append: i
                        render 'block-menu-item', type: 'custom_content', image: block.settings[image_setting], heading: block.settings[heading_setting], subheading: block.settings[subheading_setting], link: block.settings[link_setting]
                      endfor
                    endcapture
                    if collections_content != blank or custom_content != blank
                      assign mega_menu_status = true
                      break
                    endif
                  endif
                endfor
              %}
              <li
                class="mobile-menu-slide-item {% if link.links.size > 0  %}dropdown {% endif %} {% if mega_menu_status %}nav-megamenu{% endif %}"
                {% if link.links.size > 0 or mega_menu_status %}
                  data-child-items
                {% endif %}
              >
                {% if link.links.size > 0 or mega_menu_status %}
                  <details class="mobile-menu-slide-dropdown-detail">
                    <summary class="mobile-menu-slide-link">
                      <a
                        href="{{ link.url }}"
                        title="{{- grandchild.title }}"
                        class="mobile-menu-slide-inner-link {{ settings.navigation_font }}-font"
                      >
                        {{- link.title -}}
                      </a>
                      <svg width="8" height="14" viewBox="0 0 8 14" fill="none" class="mobile-menu-slide-icon">
                        <path d="M0.999999 0.666675L7.16666 6.83334L1 13" stroke="currentColor" stroke-width="1.3"
                          stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                    </summary>
                    <div class="mobile-menu-slide-dropdowns">
                      <button type="button" class="menu-back" bold data-backtonav-items>
                        <svg width="7" height="10" viewBox="0 0 7 10" fill="none">
                          <path d="M5.67348 1.00041L1.54593 5.20253L5.74805 9.33008" stroke="currentColor" stroke-width="1.25"
                            stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        {{- link.title -}}
                      </button>
                      <ul class="mobile-menu-slide-inner-menu">
                        {% for childlink in link.links %}
                          <li
                            class="mobile-menu-slide-item {% if childlink.links.size > 0 %}dropdown nav-grandmenu{% endif %}"
                            {% if link.links.size > 0 or mega_menu_status %}
                              data-child-items
                            {% endif %}
                          >
                            {% if childlink.links.size > 0 %}
                              <details class="mobile-menu-slide-dropdown-detail">
                                <summary class="mobile-menu-slide-link nav-dropdown-item">
                                  <a
                                    href="{{ link.url }}"
                                    title="{{- grandchild.title }}"
                                    class="mobile-menu-slide-inner-link {{ settings.navigation_font }}-font"
                                  >
                                    {{- childlink.title -}}
                                  </a>
                                  <svg
                                    width="8"
                                    height="14"
                                    viewBox="0 0 8 14"
                                    fill="none"
                                    class="mobile-menu-slide-icon"
                                  >
                                    <path d="M0.999999 0.666675L7.16666 6.83334L1 13" stroke="currentColor" stroke-width="1.3"
                                      stroke-linecap="round" stroke-linejoin="round" />
                                  </svg>
                                </summary>
                                <div class="mobile-menu-slide-dropdowns">
                                  <button
                                    type="button"
                                    class="menu-back {{ settings.navigation_font }}-font"
                                    bold
                                    data-subbacktonav-items
                                  >
                                    <svg width="7" height="10" viewBox="0 0 7 10" fill="none">
                                      <path opacity="0.5" d="M5.67348 1.00041L1.54593 5.20253L5.74805 9.33008" stroke="currentColor"
                                        stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                    {{- childlink.title -}}
                                  </button>
                                  <ul class="nav-grand-menu">
                                    {% for grandchild in childlink.links %}
                                      <li class="mobile-menu-slide-item">
                                        <a
                                          href="{{ grandchild.url }}"
                                          title="{{- grandchild.title }}"
                                          class="mobile-menu-slide-link {{ settings.navigation_font }}-font"
                                        >
                                          {{- grandchild.title -}}
                                        </a>
                                      </li>
                                    {% endfor %}
                                  </ul>
                                </div>
                              </details>
                            {% else %}
                              <a
                                href="{{ childlink.url }}"
                                title="{{- childlink.title }}"
                                class="mobile-menu-slide-link {{ settings.navigation_font }}-font"
                              >
                                {{- childlink.title -}}
                              </a>
                            {% endif %}
                          </li>
                        {% endfor %}

                        <li>
                          {% if mega_menu_status %}
                            <div class="megamenu-card--inner">
                              {% if collections_content != blank %}
                                <div class="megamenu-items">
                                  <ul role="list" class="list-style-none megamenu-coll--listing">
                                    {{ collections_content }}
                                  </ul>
                                </div>
                              {% endif %}

                              {% if custom_content != blank %}
                                {{ custom_content }}
                              {% endif %}
                            </div>
                          {% endif %}
                        </li>
                      </ul>
                    </div>
                  </details>
                {% else %}
                  <a
                    href="{{ link.url }}"
                    class="mobile-menu-slide-link {{ settings.navigation_font }}-font"
                    title="{{ link.title }}"
                  >
                    {{- link.title -}}
                  </a>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>
        <div class="mobile-menu-slide-account">
          {% if section.settings.enable_social_account %}
            <ul class="list-style-none social-icons">
              {% render 'social-icons' %}
            </ul>
          {% endif %}
          <div class="mobile-accounts">
            {%- if shop.customer_accounts_enabled and section.settings.enable_account -%}
              <div class="user-account">
                <a
                  href="{%- if customer -%}{{- routes.account_url -}}{%-else-%}{{ routes.account_login_url }}{%- endif -%}"
                  class="user"
                  title="{%- if customer -%}{{ 'customer.account_fallback' | t }}{%-else-%}{{ 'customer.log_in' | t }}{%- endif -%}"
                  {% if customer %}
                    data-account
                  {% elsif settings.drawer_login %}
                    data-account-head data-drawer-id="login-drawer"
                  {% endif %}
                >
                  {{'customer.account.title' | t}}
                </a>
              </div>
            {% endif %}

            {% if section.settings.enable_localiztion %}
              {% render 'header-localization-form', section: section %}
            {% endif %}
          </div>
        </div>
      </div>
    </drawer-mobile-menu>
  </mobile-hamburger-menu>
{% endif %}
