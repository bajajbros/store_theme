{% assign current_variant = product_card.selected_or_first_available_variant %}
{%- liquid
  if media_ratio == 'landscape'
    assign mediaratio = 75
  elsif media_ratio == 'square'
    assign mediaratio = 100
  elsif media_ratio == 'portrait'
    assign mediaratio = 125
  else
    if product_card.featured_media != blank
      assign mediaratio = 1 | divided_by: product_card.featured_media.preview_image.aspect_ratio | times: 100
    else
      assign mediaratio = 100
    endif
  endif
-%}
<product-bundle-card class="product-bundle-item" data-variant-id="{{ current_variant.id }}">
  <product-card class="product-card-wrapper">
    <div class="product-card-media">
      <a
        href="{{ product_card.url | within : collection }}"
        aria-label="{{ product_card.title }}"
        {% if product_card == blank %}
          aria-disabled="true"
        {% endif %}
        tabindex="-1"
        class="media-ratio"
        {% if content != false %}
          style="--media-ratio:{{ mediaratio }}%"
        {% endif %}
      >
        {%- if product_card.featured_media != blank -%}
          <img
            srcset="
              {%- if product_card.featured_media.width >= 165 -%}{{ product_card.featured_media | image_url: width: 165 }} 165w,{%- endif -%}
              {%- if product_card.featured_media.width >= 360 -%}{{ product_card.featured_media | image_url: width: 360 }} 360w,{%- endif -%}
              {%- if product_card.featured_media.width >= 533 -%}{{ product_card.featured_media | image_url: width: 533 }} 533w,{%- endif -%}
              {%- if product_card.featured_media.width >= 720 -%}{{ product_card.featured_media | image_url: width: 720 }} 720w,{%- endif -%}
              {%- if product_card.featured_media.width >= 940 -%}{{ product_card.featured_media | image_url: width: 940 }} 940w,{%- endif -%}
              {%- if product_card.featured_media.width >= 1066 -%}{{ product_card.featured_media | image_url: width: 1066 }} 1066w,{%- endif -%}
              {{ product_card.featured_media | image_url }} {{ product_card.featured_media.width }}w
            "
            src="{{ product_card.featured_media | image_url: width: 533 }}"
            sizes="(min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
            alt="{{ product_card.featured_media.alt | escape }}"
            class="product-card--img"
            loading="lazy"
            width="{{ product_card.featured_media.width }}"
            height="{{ product_card.featured_media.height }}"
          >
          {%- if product_card.media[1] != blank -%}
            <img
              srcset="
                {%- if product_card.media[1].width >= 165 -%}{{ product_card.media[1] | image_url: width: 165 }} 165w,{%- endif -%}
                {%- if product_card.media[1].width >= 360 -%}{{ product_card.media[1] | image_url: width: 360 }} 360w,{%- endif -%}
                {%- if product_card.media[1].width >= 533 -%}{{ product_card.media[1] | image_url: width: 533 }} 533w,{%- endif -%}
                {%- if product_card.media[1].width >= 720 -%}{{ product_card.media[1] | image_url: width: 720 }} 720w,{%- endif -%}
                {%- if product_card.media[1].width >= 940 -%}{{ product_card.media[1] | image_url: width: 940 }} 940w,{%- endif -%}
                {%- if product_card.media[1].width >= 1066 -%}{{ product_card.media[1] | image_url: width: 1066 }} 1066w,{%- endif -%}
                {{ product_card.media[1] | image_url }} {{ product_card.media[1].width }}w
              "
              src="{{ product_card.media[1] | image_url: width: 533 }}"
              sizes="(min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
              alt="{{ product_card.media[1].alt | escape }}"
              class="product-card-hover--img"
              loading="lazy"
              width="{{ product_card.media[1].width }}"
              height="{{ product_card.media[1].height }}"
            >
          {%- endif -%}
        {% else %}
          {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </a>
    </div>
    <div class="product-bundle--content">
      <span class="product-card-title">
        <a
          href="{{ product_card.url | within : collection }}"
          {% if product_card == blank %}
            aria-disabled="true"
          {% endif %}
        >
          {% if product_card.title %}
            {{- product_card.title | strip_html -}}
          {% else %}
            {{ 'onboarding.product_title' | t }}
          {% endif %}
        </a>
      </span>
      <product-price-list class="product-price-list">
        {%- assign price_min = product_card.price_min | default: 1899 | money -%}
        <product-sale-price class="product-price-actual">
          {%- if product_card.price_varies -%}
            <span
              class="product-actual-price varies-price"
              data-price="{{ product_card.price_min | default: 1899 | money_without_currency }}"
            >
              {{ 'products.product.price.from_price_html' | t: price: price_min }}
            </span>
          {%- else -%}
            <span
              class="product-actual-price"
              data-price="{{ product_card.price_min | default: 1899 | money_without_currency }}"
            >
              {{- price_min -}}
            </span>
          {%- endif -%}
          {%- if product_card.compare_at_price_min > product_card.price_min -%}
            <small class="product-compare-price">{{ product_card.compare_at_price_min | money }}</small>
          {%- endif -%}
          {%- if current_variant.unit_price_measurement -%}
            <span class="product-unit-price">
              {{ current_variant.unit_price | money }} /
              {% if current_variant.unit_price_measurement.reference_value != 1 -%}
                {{- current_variant.unit_price_measurement.reference_value -}}
              {%- endif %}
              {{ current_variant.unit_price_measurement.reference_unit }}
            </span>
          {%- endif -%}
        </product-sale-price>
      </product-price-list>
      <div
        class="product-bundle-button"
      >
        <button
          {% if current_variant.available == false or bundle == false %}
            disabled
          {% endif %}
          class="button button-xsm {{ settings.button_font }}-font"
        >
          {% if current_variant.available == false %}
            {{'sections.bundle.soldout' | t}}
          {% else %}
            {{'sections.bundle.add' | t}}
          {% endif %}
        </button>
      </div>
      <div class="product-bundle-button">
        <button class="button button-xsm hidden {{ settings.button_font }}-font">{{'sections.bundle.remove' | t}}</button>
      </div>
    </div>
  </product-card>
</product-bundle-card>
