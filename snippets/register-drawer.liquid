<account-drawer
  class="drawer drawer-account color-{{ section.settings.color_scheme }}"
  id="loginccount-drawer"
  role="dialog"
  data-drawer-open
  data-drawer-id="register-drawer"
>
  <div class="overlay" data-drawer-close></div>
  <div class="drawer-base">
    <modal-dialog-head class="modal-dialog-head">
      {% if section.settings.heading != blank %}
        <{{ section.settings.heading_seo }} class="section-title body-font {{ section.settings.heading_size }}">
          {{- section.settings.heading -}}
        </{{ section.settings.heading_seo }}>
      {% endif %}
      <a href="#" class="drawer-close" data-drawer-close aria-label="close">
        <close-btn>
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 1L1 21M1 1L21 21" stroke="currentColor" stroke-linecap="square" stroke-linejoin="round"/>
          </svg>
        </close-btn>
      </a>
    </modal-dialog-head>
    <modal-dialog-form class="modal-dialog-form">
      <div class="customer_wrapper">
        <div id="login">
          {% if section.settings.description != blank %}
            <div class="customer-head">
              {% if section.settings.description != blank %}
                <div class="section-description {{ section.settings.description_size }}">
                  {{ section.settings.description | newline_to_br }}
                </div>
              {% endif %}
            </div>
          {% endif %}
          <div class="customer-form-wrapper">
            {%- form 'create_customer', novalidate: 'novalidate', class: 'account-form flex column' -%}
              {%- if form.errors -%}
                <div id="error-message" role="alert" class="alert alert-warning">
                  <div class="alert-content">
                    <p class="" tabindex="-1">{{ 'templates.contact.form.error_heading' | t }}</p>
                  </div>
                  <ul class="error-listing-content">
                    {%- for field in form.errors -%}
                      <li>
                        {%- if field == 'form' -%}
                          {{ form.errors.messages[field] }}
                        {%- else -%}
                          <a href="#Customer-{{ field }}">
                            {{ form.errors.translated_fields[field] | capitalize }}
                            {{ form.errors.messages[field] }}
                          </a>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              {% endif %}
              <div class="form-control">
                <label for="RegisterForm-FirstName" class="hidden">{{ 'customer.register.first_name' | t }}</label>
                <input
                  type="text"
                  name="customer[first_name]"
                  id="RegisterFormFirstName"
                  autocomplete="given-name"
                  placeholder="{{ 'customer.register.first_name' | t }}"
                  class="input"
                >
              </div>
              <div class="form-control">
                <label for="RegisterForm-LastName" class="hidden">{{ 'customer.register.last_name' | t }} </label>
                <input
                  type="text"
                  name="customer[last_name]"
                  id="RegisterFormLastName"
                  autocomplete="family-name"
                  placeholder="{{ 'customer.register.last_name' | t }}"
                  class="input"
                >
              </div>
              <div class="form-control">
                <label for="RegisterForm-email" class="hidden">{{ 'customer.register.email' | t }}</label>
                <input
                  type="email"
                  name="customer[email]"
                  id="RegisterFormEmail"
                  autocomplete="email"
                  autocapitalize="off"
                  {% if form.email %}
                    value="{{ form.email }}"
                  {% endif %}
                  spellcheck="false"
                  {% if form.errors contains 'email' %}
                    aria-invalid="true"
                    aria-describedby="Customer-Email-error"
                  {% endif %}
                  placeholder="{{ 'customer.register.email' | t }}"
                  pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)*[a-zA-Z]{2,}))$"
                  required
                  class="input"
                >
              </div>
              <div class="form-control">
                <label for="RegisterForm-password" class="hidden">{{ 'customer.register.password' | t }}</label>
                <input
                  type="password"
                  name="customer[password]"
                  id="RegisterFormPassword"
                  autocapitalize="off"
                  {% if form.errors contains 'password' %}
                    aria-invalid="true"
                    aria-describedby="signUpForm-password-error"
                  {% endif %}
                  placeholder="{{ 'customer.register.password' | t }}"
                  required
                  class="input"
                >
              </div>
              <button type="submit" class="button button-md w-100 {{ settings.button_font }}-font">
                {{ 'customer.register.submit' | t }}
              </button>
              <a
                href="{{ routes.account_login_url }}"
                class="underline"
                data-account-head
                data-drawer-id="login-drawer"
              >
                {{'customer.log_in' | t}}
              </a>
            {% endform %}
            {% if section.settings.heading_side != blank or section.settings.content_side != blank %}
              <div class="customer-content">
                {% if section.settings.heading_side != blank %}
                  <h5>{{ section.settings.heading_side }}</h5>
                {% endif %}
                {% if section.settings.content_side != blank %}
                  <div class="rte">{{ section.settings.content_side }}</div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </modal-dialog-form>
  </div>
</account-drawer>
