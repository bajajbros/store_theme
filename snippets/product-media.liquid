{% assign slider_enable = false %}
{% if section.settings.product_template_type == 'template1'
  or section.settings.product_template_type == 'template2'
  or section.settings.product_template_type == 'template5'
  or quickview == true
  or template == 'template2'
%}
{% if product.media.size > 2 %}
  {% assign slider_enable = true %}
{% endif %}
{% endif %}
{% assign media_ratio = section.settings.image_size %}

<product-gallery-media
  {{ media_ratio }}
  class="main-product-media-wrapper {% if  section.settings.product_template_type  != 'template1'  %}featured-gallery-card{% endif %} product-media-{{ section.settings.product_template_type }} {% if slider_enable %}slider-enable  {% if template == 'template2' and product.media.size > 2 %} thumbnail-enable{% endif %}{% endif %}"
  id="productmedia-{{ section.id }}"
  data-thumbnail-enable="{%- if template == 'template2' and product.media.size > 2 -%}true{% else %}false {% endif %}"
  data-id="{{ section.id }}"
  {% if quickview == true %}
    data-quick-view
  {% endif %}
>
  {%- if template == 'template2' and product.media.size > 2 -%}
    <div class="featured-slider--nav">
      <div
        id="main-product-thumbnail-{{ section.id }}"
        class="swiper featured-nav--thumb"
        data-product-thumbs-{{ section.id }}
      >
        <div class="swiper-wrapper">
          {%- if current_variant.featured_media != null -%}
            {%- assign featured_media = current_variant.featured_media -%}
            <div class="swiper-slide"  role="img">
              {{
                featured_media.preview_image
                | image_url: width: 500
                | image_tag: loading: lazy, sizes: '50vw', widths: '150, 200, 300, 400'
              }}
            </div>
          {% endif %}
          {% for media in product.media %}
            {% unless media.id == current_variant.featured_media.id %}
              <div class="swiper-slide"  role="img">
                {{
                  media.preview_image
                  | image_url: width: 500
                  | image_tag: loading: lazy, sizes: '50vw', widths: '150, 200, 300, 400'
                }}
              </div>
            {% endunless %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
  <div
    class="swiper featured-product-slider"
    {% if slider_enable %}
      data-product-media-{{ section.id }}
      data-product-images="main-product-images-{{ section.id }}"
    {% endif %}
    data-product-main-media
  >
    <div class="swiper-wrapper product-media-popup-images" data-main-product-media>
      {%- if product.media.size > 0 -%}
        {%- if current_variant.featured_media != null -%}
          {%- assign featured_media = current_variant.featured_media -%}

          {%- liquid
            if media_ratio == 'landscape'
              assign mediaratio = 75
            elsif media_ratio == 'square'
              assign mediaratio = 100
            elsif media_ratio == 'portrait'
              assign mediaratio = 125
            else
              if featured_media != blank
                assign mediaratio = 1 | divided_by: featured_media.preview_image.aspect_ratio | times: 100
              else
                assign mediaratio = 100
              endif
            endif
          -%}
          <div
            class="swiper-slide"
            data-slide-index="{{ forloop.index0 }}"
            id="product-media-{{ current_variant.featured_media.id }}"
            data-media-product
            role="img"
           
          >
            <div
              class="media-ratio"
              style="--media-ratio:{{ mediaratio }}%"
            >
              {{
                featured_media.preview_image
                | image_url: width: 1946
                | image_tag:
                  loading: lazy,
                  sizes: '100vw',
                  widths: '246, 493, 600, 713, 823, 990, 1100, 1206, 1346, 1426, 1646, 1946'
              }}

              {% if zoomImage != false %}
                <a
                  href="{{  featured_media.preview_image | image_url }}"
                  class="product-media-zoom"

                  data-pswp-height="1400"
                  data-pswp-width="1200"
                  target="_blank"
                  tabindex="-1"
                  aria-label="Zoom"
                  data-index=""
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M13 4.5V1.70719L7.70625 7L13 12.2937V9.5C13 9.22363 13.2236 9 13.5 9C13.7764 9 14 9.22363 14 9.5V13.5C14 13.7764 13.7764 14 13.5 14H9.5C9.22363 14 9 13.7764 9 13.5C9 13.2236 9.22363 13 9.5 13H12.2931L7 7.70625L1.70719 13H4.5C4.775 13 5 13.225 5 13.5C5 13.775 4.775 14 4.5 14H0.5C0.223625 14 0 13.775 0 13.5V9.5C0 9.225 0.223625 9 0.5 9C0.776375 9 1 9.225 1 9.5V12.2931L6.29375 7L1 1.70719V4.5C1 4.775 0.77625 5 0.5 5C0.22375 5 0 4.775 0 4.5V0.5C0 0.22375 0.223625 0 0.5 0H4.5C4.775 0 5 0.22375 5 0.5C5 0.77625 4.775 1 4.5 1H1.70719L7 6.29375L12.2937 1H9.5C9.225 1 9 0.77625 9 0.5C9 0.22375 9.225 0 9.5 0H13.5C13.775 0 14 0.22375 14 0.5V4.5C14 4.775 13.775 5 13.5 5C13.225 5 13 4.775 13 4.5Z" fill="currentcolor"/>
                  </svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
        {% for media in product.media %}
          {%- liquid
            if media_ratio == 'landscape'
              assign mediaratio = 75
            elsif media_ratio == 'square'
              assign mediaratio = 100
            elsif media_ratio == 'portrait'
              assign mediaratio = 125
            else
              if media != blank
                assign mediaratio = 1 | divided_by: media.preview_image.aspect_ratio | times: 100
              else
                assign mediaratio = 100
              endif
            endif
          -%}
          {% unless media.id == current_variant.featured_media.id %}
            {% case media.media_type %}
              {% when 'image' %}
                <div id="product-media-{{ media.id }}" class="swiper-slide" data-media-product role="img">
                  <div
                    class="media-ratio"
                    style="--media-ratio:{{ mediaratio }}%"
                  >
                    {{
                      media.preview_image
                      | image_url: width: 1946
                      | image_tag:
                        loading: lazy,
                        sizes: '100vw',
                        widths: '246, 493, 600, 713, 823, 990, 1100, 1206, 1346, 1426, 1646, 1946'
                    }}
                    {% if zoomImage != false %}
                      <a
                        href="{{ media.preview_image | image_url }}"
                        class="product-media-zoom"

                        data-pswp-height="1400"
                        data-pswp-width="1200"
                        target="_blank"
                        tabindex="-1"
                        aria-label="Zoom"
                        data-index=""
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                          <path d="M13 4.5V1.70719L7.70625 7L13 12.2937V9.5C13 9.22363 13.2236 9 13.5 9C13.7764 9 14 9.22363 14 9.5V13.5C14 13.7764 13.7764 14 13.5 14H9.5C9.22363 14 9 13.7764 9 13.5C9 13.2236 9.22363 13 9.5 13H12.2931L7 7.70625L1.70719 13H4.5C4.775 13 5 13.225 5 13.5C5 13.775 4.775 14 4.5 14H0.5C0.223625 14 0 13.775 0 13.5V9.5C0 9.225 0.223625 9 0.5 9C0.776375 9 1 9.225 1 9.5V12.2931L6.29375 7L1 1.70719V4.5C1 4.775 0.77625 5 0.5 5C0.22375 5 0 4.775 0 4.5V0.5C0 0.22375 0.223625 0 0.5 0H4.5C4.775 0 5 0.22375 5 0.5C5 0.77625 4.775 1 4.5 1H1.70719L7 6.29375L12.2937 1H9.5C9.225 1 9 0.77625 9 0.5C9 0.22375 9.225 0 9.5 0H13.5C13.775 0 14 0.22375 14 0.5V4.5C14 4.775 13.775 5 13.5 5C13.225 5 13 4.775 13 4.5Z" fill="currentcolor"/>
                        </svg>
                      </a>
                    {% endif %}
                  </div>
                </div>
              {%- when 'external_video' -%}
                {% assign video_class = 'no-js-hidden product-media-' | append: media.host %}

                <div id="product-media-{{ media.id }}" class="swiper-slide" role="img">
                  <div
                    class="media-ratio"
                    style="--media-ratio:{{ mediaratio }}%"
                    tabindex="-1"
                  >
                    {% if media.host == 'youtube' %}
                      {{
                        media
                        | external_video_url: autoplay: false, playlist: media.external_id
                        | external_video_tag: class: video_class, loading: 'lazy'
                      }}
                    {% else %}
                      {{
                        media
                        | external_video_url: autoplay: false, playlist: media.external_id
                        | external_video_tag: class: video_class, loading: 'lazy'
                      }}
                    {% endif %}
                    <noscript>
                      <a
                        href="{{ media | external_video_url }}"
                        target="_blank"
                        class="unstyled-link"
                        aria-label="{{ media.alt | default: product.title | strip_html }}"
                      >
                        {% comment %}theme-check-disable ImgWidthAndHeight{% endcomment %}
                        <img
                          src="{{ media.preview_image | image_url: width: '[246, 493, 600, 713, 823, 990, 1100, 1206, 1346, 1426, 1646, 1946]' }}"
                          alt="{{ media.preview_image.alt | escape }}"
                          loading="lazy"
                        >
                        {% comment %}theme-check-enable ImgWidthAndHeight{% endcomment %}
                      </a>
                    </noscript>
                  </div>
                </div>
              {%- when 'video' -%}
                {%- liquid
                  assign video_class = 'no-js-hidden product-video-media'
                  assign video_url = media.sources[0]
                  if media.sources[1] != blank
                    assign video_url = media.sources[1]
                  endif
                %}
                <div
                  id="product-media-{{ media.id }}"
                  class="swiper-slide"
                  data-media-id="{{ media.id }}"
                  tabindex="-1"
                  role="img"
                >
                  <div
                    class="media-ratio"
                    style="--media-ratio:{{ mediaratio }}%"
                  >
                    {{
                      media
                      | media_tag:
                        image_size: '2048x',
                        autoplay: false,
                        controls: true,
                        preload: 'none',
                        class: video_class
                    }}
                    <noscript>
                      <a href="{{ video_url.url  }}" target="_blank">
                        {% comment %}theme-check-disable ImgWidthAndHeight{% endcomment %}
                        <img
                          src="{{ media.preview_image | image_url: width: 2048 }}"
                          alt="{{ media.preview_image.alt | escape }}"
                          loading="lazy"
                          aria-label="{{ media.alt | default: product.title | strip_html }}"
                        >
                        {% comment %}theme-check-enable ImgWidthAndHeight{% endcomment %}
                      </a>
                    </noscript>
                  </div>
                </div>
              {%- when 'model' -%}
                {%- liquid
                  if media.preview_image.aspect_ratio
                  endif
                -%}
                <product-model
                  id="product-media-{{ media.id }}"
                  class="product-model-element swiper-slide product-media-model"
                  role="img"
                >
                  <div
                    class="media-ratio no-js-hidden"
                    data-media-id="{{ media.id }}"
                  >
                    {{
                      media
                      | model_viewer_tag:
                        image_size: true,
                        reveal: 'interaction',
                        toggleable: true,
                        data-model-id: media.id
                    }}
                    <button class="close-product-model hidden">
                      <svg width="12" height="12" viewBox="0 0 22 22" fill="none">
                        <path d="M21.7987 20.826L11.9721 10.9958L21.7987 1.16552C22.0561 0.899047 22.0561 0.476499 21.7987 0.20994C21.5349 -0.0632507 21.0997 -0.0708067 20.8266 0.193065L11 10.0233L1.17343 0.193149C0.907055 -0.0642582 0.484664 -0.0642582 0.218204 0.193149C-0.0548867 0.457021 -0.0624398 0.892415 0.201335 1.16561L10.0279 10.9958L0.201335 20.826C0.0724268 20.9549 1.71925e-08 21.1298 1.71925e-08 21.3122C-8.39964e-05 21.692 0.307751 21.9999 0.687425 22C0.869793 22.0002 1.04469 21.9276 1.17343 21.7984L11 11.9682L20.8266 21.7985C20.9553 21.9277 21.1303 22.0002 21.3127 22C21.4949 21.9999 21.6696 21.9275 21.7985 21.7987C22.0671 21.5301 22.0672 21.0946 21.7987 20.826Z" fill="currentColor"></path>
                      </svg>
                    </button>
                    <button
                      class="product-model-button button no-js-hidden"
                      type="button"
                      aria-label="view in your space"
                      data-shopify-xr
                      data-shopify-model3d-id="{{ media.id }}"
                      data-shopify-title="title"
                      data-shopify-xr-hidden
                    >
                      <span>{{ 'products.product.xr_button' | t }}</span>
                    </button>
                  </div>

                  {% comment %}theme-check-disable ImgWidthAndHeight,ImgLazyLoading{% endcomment %}
                  <noscript>
                    <img
                      src="{{ media.preview_image | image_url: width: 2048 }}"
                      alt="{{ media.preview_image.alt | escape }}"
                      aria-label="{{ media.alt | default: product.title | strip_html }}"
                    >
                  </noscript>
                  {% comment %}theme-check-enable ImgWidthAndHeight,ImgLazyLoading{% endcomment %}
                </product-model>
            {% endcase %}
          {% endunless %}
        {% endfor %}

      {% else %}
        <div id="product-media-placeholder-svg" class="swiper-slide" data-media-product role="img">
          <div
            class="media-ratio"
            style="--media-ratio:100%"
          >
            {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        </div>
      {% endif %}
    </div>
    {% if slider_enable and quickview == true or slider_enable
      and section.settings.product_template_type == 'template1'
    %}
    {% if product.media.size > 2 %}
      <div class="swiper-counter swipper-counter-{{ section.id }}"></div>
      {% endif %}
    {% endif %}
    {% if slider_enable and product.media.size > 2 %}
      <div class="slider-controls">
        <div class="swiper-button-prev swiper-button swiper-button-prev-{{ section.id }}"></div>
        <div class="swiper-button-next swiper-button swiper-button-next-{{ section.id }}"></div>
      </div>
    {% endif %}
  </div>
</product-gallery-media>
