<cart-drawer
  class="drawer drawer-add-to-cart"
  id="cart-drawer"
  role="dialog"
  data-url="?section_id=cart-drawer"
  data-id="{{ section.id }}"
>
  <div class="overlay" data-drawer-close></div>
  <div class="drawer-base">
    <modal-dialog-head class="modal-dialog-head">
      <h4 class="drawer-heading h4">
        {{ 'templates.cart.cart' | t }}
        <span class="drawer-results">({{ cart.item_count }})</span>
      </h4>
      <a href="#" class="drawer-close" data-drawer-close>
        <close-btn>
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M21 1L1 21M1 1L21 21" stroke="currentColor" stroke-linecap="square" stroke-linejoin="round"></path>
          </svg>
        </close-btn>
      </a>
    </modal-dialog-head> 
    <modal-dialog-form
      id="cart-drawer-body-content"
      class="modal-dialog-form {% if cart.item_count == 0 %}empty-cart-drawer{% else %} section-{{ id }}{% endif %}"
      data-cart-count="{{ cart.item_count }}"
      data-cart-price="{{ cart.total_price }}"
    >
      {% if cart.item_count == 0 %}
        <div class="cart-drawer-empty">
          <div class="cart-drawer-empty-inner text-align-center">
            <svg
              class="cart-empty-icon"
              width="42"
              height="42"
              viewBox="0 0 42 42"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M36.7762 7.875H30.87V4.59375C30.87 2.07375 28.8225 0 26.2762 0H15.75C13.23 0 11.1563 2.0475 11.1563 4.59375V7.875H5.25001C2.3625 7.875 0 10.2113 0 13.125V36.75C0 39.6375 2.33625 42 5.25001 42H36.75C39.6375 42 42 39.6637 42 36.75V13.125C42 10.2375 39.6637 7.875 36.75 7.875H36.7762ZM15.12 4.59375C15.12 4.22625 15.4088 3.9375 15.7762 3.9375H26.3025C26.67 3.9375 26.9587 4.22625 26.9587 4.59375V7.875H15.1463V4.59375H15.12ZM38.0887 36.7762C38.0887 37.485 37.5112 38.0887 36.7762 38.0887H5.27626C4.56751 38.0887 3.96376 37.5112 3.96376 36.7762V13.1513C3.96376 12.4425 4.54126 11.8388 5.27626 11.8388H11.1825V15.7763H15.12V11.8388H26.9325V15.7763H30.87V11.8388H36.7762C37.485 11.8388 38.0887 12.4163 38.0887 13.1513V36.7762Z" fill="currentColor"></path>
            </svg>
            <div class="cart-empty-title h5 body-font">{{ 'general.cart.empty' | t }}</div>

            {% if settings.empty_text != blank %}
              <div class="rte">
                <p>{{ settings.empty_text }}</p>
              </div>
            {% endif %}

            <a
              href="{{ routes.all_products_collection_url }}"
              class="button button-md w-100 {{ settings.button_font }}-font"
            >
              {{ 'general.continue_shopping' | t }}
            </a>
            <div class="cart-login-wrapper">
              <p class="cart-title-login text-xxl heading-font">{{ 'general.cart.account' | t }}</p>
              <span class="text-sm">
               <a href="{{- routes.account_login_url-}}" class="underline--link">
                    <span class="button-text">{{'general.cart.login' | t}}</span
                    ><span class="link-arrow">
                      <svg width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M0 0H8V8H7V1.707L1.354 7.354L1 7.707L0.293 7L0.646 6.646L6.293 1H0V0Z" fill="currentColor"></path>
                      </svg>
                    </span> </a
                  >&nbsp;{{ 'general.cart.checkout_faster' | t }}</span
                >
            </div>

            {% if settings.collection_list != blank %}
              <div class="cart-drawer-empty-collections">
                {% for collection_list in settings.collection_list %}
                  <a href="{{ collection_list.url }}" class="cart-empty-collections-item">
                    {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                    {%- assign placeholder_image = 'product-apparel-' | append: current -%}

                    {% if collection_list.featured_image != blank %}
                      {%- assign widths = '50, 100, 200, 300, 400, 500' -%}
                      {%- capture sizes -%}
                            calc((100vw - 50px) / 2)
                          {%- endcapture -%}
                      {{
                        collection_list.featured_image
                        | image_url: width: 500
                        | image_tag: sizes: sizes, widths: widths
                      }}
                    {% else %}
                      {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                    <span class="cart-empty-collections-title text-base">{{ collection_list.title }}</span>
                  </a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      {% else %}
        <div class="cart-content">
          {% if cart.item_count > 0 %}
            {%- if settings.show_shipping and settings.shipping_rate != blank and cart.item_count > 0 -%}
              <free-shipping-bar class="free-shipping-bar flex column hidden" data-main-shipping-bar>
                <div class="free-shipping-bar-message text-sm"></div>
                <div
                  class="progress-bar"
                  role="progressbar"
                  aria-valuemin="0"
                >
                  <span class="progress"></span>
                </div>
              </free-shipping-bar>
            {% endif %}
          {% endif %}

          <div class="cart-content-items">
            <cart-items-data>
              <form class="cartdrawer-form" action="{{ routes.cart_url }}" method="post" id="cart" data-cart-form>
                {% assign giftwrap_productenable = false %}
                {%- for item in cart.items -%}
                  {% liquid
                    assign giftwrapproduct = false
                    if item.product_id == settings.gift_wrap_product.id
                      assign giftwrap_productenable = true
                      assign giftwrapproduct = true
                    endif
                  %}
                  <cart-item id="cart-item-{{forloop.index}}" data-cart-item>
                    <div class="cart-product">
                      {%- if item.image != blank -%}
                        <a href="{{ item.url }}" class="cart-product-image">
                          <img
                            class="product--image"
                            src="{{ item.image | image_url: width: 300 }}"
                            alt="{{ item.image.alt | escape }}"
                            loading="lazy"
                            width="150"
                            height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                          >
                        </a>
                      {% endif %}
                      <cart-item-info class="cart-product-info text-sm">
                        <a href="{{ item.url }}" class="product-title font-heading">
                          {{ item.product.title | escape -}}
                        </a>
                        {%- if item.product.has_only_default_variant == false
                          or item.properties.size != 0
                          or item.selling_plan_allocation != null
                        -%}
                          <dl>
                            {%- if item.product.has_only_default_variant == false -%}
                              {%- for option in item.options_with_values -%}
                                <div class="cart-product-options text-xs">
                                  <dt>{{ option.name }}:</dt>
                                  <dd>{{ option.value }}</dd>
                                </div>
                              {%- endfor -%}
                            {%- endif -%}

                            {%- for property in item.properties -%}
                              {%- assign property_first_char = property.first | slice: 0 -%}
                              {%- if property.last != blank and property_first_char != '_' -%}
                                <div class="cart-product-options text-xs">
                                  <dt>{{ property.first }}:</dt>
                                  <dd>
                                    {%- if property.last contains '/uploads/' -%}
                                      <a href="{{ property.last }}" class="link" target="_blank">
                                        {{ property.last | split: '/' | last }}
                                      </a>
                                    {%- else -%}
                                      {{ property.last }}
                                    {%- endif -%}
                                  </dd>
                                </div>
                              {%- endif -%}
                            {%- endfor -%}
                          </dl>
                          <p class="cart-product-options text-xs">
                            {{ item.selling_plan_allocation.selling_plan.name }}
                          </p>
                        {%- endif -%}
                        <div class="product-badge text-xs" aria-label="{{ 'customer.order.discount' | t }}">
                          {%- for discount in item.line_level_discount_allocations -%}
                            <sapn class="badge discount_title">
                              {{ discount.discount_application.title }}
                            </sapn>
                          {%- endfor -%}
                        </div>

                        <product-price-list class="product-price-list">
                          <product-sale-price>
                            {%- if item.original_line_price != item.final_line_price -%}
                              <span class="hidden">
                                {{ 'products.product.price.sale_price' | t }}
                              </span>
                              <span class="product-price-actual bold">
                                {{ item.final_line_price | money }}
                              </span>
                              <span class="hidden">
                                {{ 'products.product.price.regular_price' | t }}
                              </span>
                              <span class="discount-price">
                                {{- item.original_line_price | money -}}
                              </span>
                            {%- else -%}
                              <span class="product-price-actual bold">
                                {{ item.original_line_price | money }}
                              </span>
                            {% endif %}
                            {%- if item.unit_price_measurement -%}
                              <span class="">
                                (
                                {{ item.unit_price | money }}
                                /
                                {%- if item.unit_price_measurement.reference_value != 1 %}
                                  {{ item.unit_price_measurement.reference_value -}}
                                {%- endif %}
                                {{ item.unit_price_measurement.reference_unit }}
                                )
                              </span>
                            {%- endif -%}
                          </product-sale-price>
                        </product-price-list>
                        {% unless giftwrapproduct %}
                          <div class="product-quantity-wrapper">
                            <quantity-element
                              id="drawer-quantity-Form-product-{{ forloop.index }}"
                              class="quantity quantity-elements"
                            >
                              <button class="quantity-minus" type="button" name="minus">
                                <svg
                                  width="10"
                                  height="2"
                                  viewBox="0 0 10 2"
                                  fill="none"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <path d="M9.5 0.5V1.5L0.5 1.5L0.5 0.5L9.5 0.5Z" fill="currentColor" stroke="currentColor"></path>
                                </svg>
                              </button>
                              <label for="drawer-quantity-{{ item.index | plus: 1 }}" class="hidden">
                                {{- 'products.product.quantity.label' | t -}}
                              </label>
                              <input
                                id="drawer-quantity-{{ item.index | plus: 1 }}"
                                class="quantity-input"
                                data-quantity-variant-id="{{ item.variant.id }}"
                                type="number"
                                name="updates[]"
                                value="{{ item.quantity }}"
                                data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                min="{{ item.variant.quantity_rule.min }}"
                                {% if item.variant.quantity_rule.max != null %}
                                  max="{{ item.variant.quantity_rule.max }}"
                                {% endif %}
                                step="{{ item.variant.quantity_rule.increment }}"
                                aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                id="drawer-quantity-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                              >
                              <button
                                class="quantity-plus"
                                type="button"
                                name="plus"
                                aria-label="Increase"
                                data-quantity-increment=""
                              >
                                <svg
                                  width="10"
                                  height="10"
                                  viewBox="0 0 10 10"
                                  fill="none"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <path d="M9.5 5.5H6.5V4.5H9.5V5.5ZM5.5 4.5V5.5L4.5 5.5V4.5H5.5ZM4.5 6.5L5.5 6.5L5.5 9.5H4.5L4.5 6.5ZM3.5 4.5V5.5H0.5L0.5 4.5H3.5ZM5.5 3.5L4.5 3.5L4.5 0.5L5.5 0.5L5.5 3.5Z" fill="currentColor" stroke="currentColor"></path>
                                </svg>
                              </button>
                            </quantity-element>
                          </div>
                        {% endunless %}

                        <div
                          class="cart-item__error"
                          id="CartDrawer-Line-item-error-{{ item.index | plus: 1 }}"
                          role="alert"
                        >
                          <small class="cart-item-error"></small>
                        </div>
                      </cart-item-info>
                      <cart-remove-item
                        class="remove-product"

                        id="drawer-remove-{{ item.index | plus: 1 }}"
                        data-index="{{ item.index | plus: 1 }}"
                      >
                        <span class="button-loader cart-remove-loader hidden">
                          <svg width="25" height="25" viewBox="0 0 100 100">
                            <circle cx="50" cy="50" fill="none" stroke="currentColor" stroke-width="6" r="35" stroke-dasharray="164.93361431346415 56.97787143782138">
                              <animateTransform attributeName="transform" type="rotate" repeatCount="indefinite" dur="1s" values="0 50 50;360 50 50" keyTimes="0;1"/>
                            </circle>
                          </svg>
                        </span>
                        <a
                          href="{{ item.url_to_remove }}"
                          class="cart-remove text-xs"
                          data-line="{{ forloop.index }}"
                          data-page="{{ section.id }}"
                          aria-label="remove"
                          data-remove-item
                        >
                          <svg
                            width="16"
                            height="16"
                            viewBox="0 0 16 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M14 3H10.47C10.4349 2.40332 10.2264 1.82986 9.87 1.35C9.44 0.82 8.8 0.5 8 0.5C7.2 0.5 6.56 0.82 6.13 1.35C5.77312 1.82958 5.56454 2.4032 5.53 3H2C1.86739 3 1.74021 3.05268 1.64645 3.14645C1.55268 3.24021 1.5 3.36739 1.5 3.5C1.5 3.63261 1.55268 3.75979 1.64645 3.85355C1.74021 3.94732 1.86739 4 2 4H3.25V14C3.25 14.28 3.47 14.5 3.75 14.5H12.25C12.3826 14.5 12.5098 14.4473 12.6036 14.3536C12.6973 14.2598 12.75 14.1326 12.75 14V4H14C14.1326 4 14.2598 3.94732 14.3536 3.85355C14.4473 3.75979 14.5 3.63261 14.5 3.5C14.5 3.36739 14.4473 3.24021 14.3536 3.14645C14.2598 3.05268 14.1326 3 14 3ZM6.91 1.98C7.14 1.69 7.49 1.5 8 1.5C8.51 1.5 8.85 1.69 9.09 1.98C9.29 2.22 9.39 2.58 9.45 3H6.55C6.6 2.58 6.72 2.22 6.91 1.98ZM11.75 13.5H4.25V4H11.75V13.5Z" fill="currentColor"></path>
                            <path d="M6.54688 5.25C6.41427 5.25 6.28709 5.30268 6.19332 5.39645C6.09955 5.49021 6.04688 5.61739 6.04688 5.75V11.75C6.04688 11.8826 6.09955 12.0098 6.19332 12.1036C6.28709 12.1973 6.41427 12.25 6.54688 12.25C6.67948 12.25 6.80666 12.1973 6.90043 12.1036C6.9942 12.0098 7.04688 11.8826 7.04688 11.75V5.75C7.04688 5.61739 6.9942 5.49021 6.90043 5.39645C6.80666 5.30268 6.67948 5.25 6.54688 5.25ZM9.44687 5.25C9.31427 5.25 9.18709 5.30268 9.09332 5.39645C8.99955 5.49021 8.94687 5.61739 8.94687 5.75V11.75C8.94687 11.8826 8.99955 12.0098 9.09332 12.1036C9.18709 12.1973 9.31427 12.25 9.44687 12.25C9.57948 12.25 9.70666 12.1973 9.80043 12.1036C9.8942 12.0098 9.94687 11.8826 9.94687 11.75V5.75C9.94687 5.61739 9.8942 5.49021 9.80043 5.39645C9.70666 5.30268 9.57948 5.25 9.44687 5.25Z" fill="currentColor"></path>
                          </svg>
                          Remove
                        </a>
                      </cart-remove-item>
                    </div>
                  </cart-item>
                {% endfor %}
              </form>
            </cart-items-data>
          </div>
          {% if settings.enable_upsell_product and settings.upsell_product != blank %}
            <product-recommendations class="product-recommendations">
              {% if settings.upsell_product_heading %}
                <div class="product-recommendations--title text-lg">{{- settings.upsell_product_heading -}}</div>
              {% endif %}

              <slider-component
                class="recommendations-slide swiper"
                data-settings='
                    {
                    "loop": true,
                    "slidesPerView": 2,
                    "centeredSlides":false,
                    "spaceBetween":"20px",
                    "navigation": {
                      "nextEl": ".swiper-button-next-{{ section.id }}",
                      "prevEl": ".swiper-button-prev-{{ section.id }}"
                    },
                  "breakpoints": {
                    "600": {
                      "slidesPerView": 3,
                      "spaceBetween":"20px"
                    }
                  }
                  }
                '
              >
                <div class="swiper-wrapper">
                  {%- for upsellProducts in settings.upsell_product -%}
                    {%- assign current_variant = upsellProducts.selected_or_first_available_variant %}
                    {% assign product_form_id = 'product-form-'
                      | append: section.id
                      | append: forloop.index
                      | append: '-'
                      | append: collection.handle
                    %}
                    <div class="product-scroll-sell swiper-slide">
                      <div class="product-scroll-image relative">
                        {%- capture current -%}{% cycle section.id: 1, 2, 3, 4 %}{%- endcapture -%}
                        {%- assign placeholder_image = 'product-apparel-' | append: current -%}
                        {% if upsellProducts.featured_media != blank %}
                          {%- assign widths = '50, 100, 200, 300, 400, 500' -%}
                          {%- capture sizes -%}
                                calc((100vw - 50px) / 2)
                                 {%- endcapture -%}
                          {{
                            upsellProducts.featured_media.preview_image
                            | image_url: width: 500
                            | image_tag: sizes: sizes, widths: widths
                          }}
                        {% else %}
                          {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}

                        {% render 'card-form',
                          product: upsellProducts,
                          cartdrawericon: true,
                          product_form_id: product_form_id,
                          class: 'addToCart-icon'
                        %}
                     
                      </div>
                      <div class="product-scroll-text text-sm">
                        <a
                          href="{{ upsellProducts.url | within : collection }}"
                          class="product-title font-heading"
                        >
                          {{- upsellProducts.title | strip_html -}}
                        </a>

                        <product-price-list
                          class="product-price-list"
                          id="product-price-list-{{ product_card.id }}-{{ section.id }}"
                        >
                          {%- assign price_min = product_card.price_min | default: 1899 | money -%}
                          <product-sale-price class="product-price-actual">
                            {%- if product_card.price_varies -%}
                              <span class="product-actual-price varies-price">
                                {{ 'products.product.price.from_price_html' | t: price: price_min }}
                              </span>
                            {%- else -%}
                              <span class="product-actual-price">{{ price_min }}</span>
                            {%- endif -%}
                            {%- if product_card.compare_at_price_min > product_card.price_min -%}
                              <small class="product-compare-price">
                                {{- product_card.compare_at_price_min | money -}}
                              </small>
                            {%- endif -%}
                            {%- if current_variant.unit_price_measurement -%}
                              <span class="product-unit-price">
                                {{ current_variant.unit_price | money }} /
                                {% if current_variant.unit_price_measurement.reference_value != 1 -%}
                                  {{- current_variant.unit_price_measurement.reference_value -}}
                                {%- endif %}
                                {{ current_variant.unit_price_measurement.reference_unit }}
                              </span>
                            {%- endif -%}
                          </product-sale-price>
                        </product-price-list>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              </slider-component>
              <div class="slider-controls">
                <div class="swiper-button-prev swiper-button swiper-button-prev-{{ section.id }}"></div>
                <div class="swiper-button-next swiper-button swiper-button-next-{{ section.id }}"></div>
              </div>
            </product-recommendations>
          {% endif %}
          {% if settings.enable_gift_wrap
            and settings.gift_wrap_product != blank
            and settings.gift_wrap_text != blank
            and settings.gift_wrap_product.available
            and giftwrap_productenable == false
          %}
            <gift-wrapping-content
              id="giftwrap"
              class="gift-wrapper"
              data-gift-product-wrapper
              data-gift-wrap-id="{{  settings.gift_wrap_product.first_available_variant.id }}"
              data-gift-wrapping="true"
              cart-items-size="{{ cart.item_count }}"
              gift-wraps-in-cart="0"
              items-in-cart="{{ cart.item_count }}"
            >
              {%- form 'product',
                settings.gift_wrap_product,
                id: 'product_gift_form_id',
                class: 'form main-product-form',
                novalidate: 'novalidate',
                data-type: 'add-to-cart-form'
              -%}
                <input type="hidden" name="id" value="{{ settings.gift_wrap_product.first_available_variant.id }}">
              {% endform %}
              <div class="giftwrap">
                <input type="checkbox" class="input-option" id="cart-drawer-gift_wrap" value="" add-gift-product>
                <label for="cart-drawer-gift_wrap">{{ settings.gift_wrap_text }}</label>
              </div>
            </gift-wrapping-content>
          {% endif %}
        </div>
      {% endif %}
    </modal-dialog-form>
    {% if cart.item_count != 0 %}
      <modal-dialog-foot
        id="cart-drawer-summary"
        class="modal-dialog-foot cart-drawer-summary"
        data-id="{{ section.id }}"
      >
        {% if settings.shipping_estimates or settings.show_cart_note %}
          <div class="modal-dialog-cart--navtabs">
            {% if settings.shipping_estimates %}
              <button class="modal-dialog-button" data-modal="estimate_shipping" tabindex="0">
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M14.4435 1.64062C14.8145 2.01172 15 2.46093 15 2.98828C15 3.49609 14.8145 3.93555 14.4435 4.30664L4.1335 14.6192L0.794482 15H0.706613C0.491822 15 0.316084 14.9218 0.179399 14.7657C0.042714 14.6093 -0.0158649 14.4238 0.00366109 14.209L0.384427 10.8692L10.6944 0.556641C11.0654 0.185547 11.5047 0 12.0124 0C12.5396 0 12.9887 0.185547 13.3597 0.556641L14.4435 1.64062ZM3.69415 13.7402L11.4266 6.00586L8.99556 3.57422L1.26312 11.3086L0.970218 14.0332L3.69415 13.7402ZM13.7991 3.63282C13.9748 3.45703 14.0627 3.24219 14.0627 2.98828C14.0627 2.71484 13.9748 2.49023 13.7991 2.31445L12.6861 1.20117C12.5104 1.02539 12.2858 0.9375 12.0124 0.9375C11.7585 0.9375 11.5438 1.02539 11.3681 1.20117L9.66923 2.90039L12.1003 5.33203L13.7991 3.63282Z" fill="currentColor"></path>
                </svg>
                {{ 'general.cart.estimate_shipping' | t }}
              </button>
              <cart-dialog class="cart-dialog" id="estimate_shipping">
                <div class="cart-dialog-wrapper relative">
                  <span class="cart-dialog-label block h6">{{ 'general.cart.shipping' | t }}</span>
                  <a href="#" aria-label="Close" class="drawer-close cart--close" data-dialog-close>
                    <close-btn>
                      <svg
                        class="icon"
                        viewBox="0 0 20 20"
                        stroke="currentColor"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15L15 5M5 5L15 15"></path>
                      </svg>
                    </close-btn>
                  </a>
                  <div class="cart-dialog-inner">
                    {% render 'shipping-estimate', section: section %}
                  </div>
                </div>
              </cart-dialog>
            {% endif %}
            {%- if settings.show_cart_note -%}
              <button class="modal-dialog-button" data-modal="cart-note" tabindex="0">
                <svg width="24" height="18" viewBox="0 0 24 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path opacity="0.7" d="M10.5 6C10.665 6 10.8 5.865 10.8 5.7V5.1C10.8 4.935 10.665 4.8 10.5 4.8H1.5C1.335 4.8 1.2 4.935 1.2 5.1V5.7C1.2 5.865 1.335 6 1.5 6H10.5ZM23.7 13.2H22.8V9.14625C22.8 8.51625 22.545 7.8975 22.095 7.45125L18.9487 4.305C18.5063 3.855 17.8875 3.6 17.2538 3.6H15.6V1.7475C15.6 0.78375 14.7675 0 13.7475 0H4.2525C3.2325 0 2.4 0.78375 2.4 1.7475V2.4H0.3C0.135 2.4 0 2.535 0 2.7V3.3C0 3.465 0.135 3.6 0.3 3.6H9.3C9.465 3.6 9.6 3.465 9.6 3.3V2.7C9.6 2.535 9.465 2.4 9.3 2.4H3.6V1.7475C3.6 1.44375 3.8925 1.2 4.2525 1.2H13.7475C14.1075 1.2 14.4 1.44375 14.4 1.7475V13.2H7.785C7.2375 12.4763 6.375 12 5.4 12C4.72125 12 4.1025 12.2325 3.6 12.615V9.6H2.4V15C2.4 16.6575 3.7425 18 5.4 18C7.0575 18 8.4 16.6575 8.4 15C8.4 14.7938 8.3775 14.595 8.34 14.4H15.66C15.6188 14.595 15.6 14.7938 15.6 15C15.6 16.6575 16.9425 18 18.6 18C20.2575 18 21.6 16.6575 21.6 15C21.6 14.7938 21.5775 14.595 21.54 14.4H23.7C23.865 14.4 24 14.265 24 14.1V13.5C24 13.335 23.865 13.2 23.7 13.2ZM5.4 16.8C4.40625 16.8 3.6 15.9938 3.6 15C3.6 14.0063 4.40625 13.2 5.4 13.2C6.39375 13.2 7.2 14.0063 7.2 15C7.2 15.9938 6.39375 16.8 5.4 16.8ZM15.6 4.8H17.2538C17.5688 4.8 17.88 4.9275 18.1013 5.1525L21.2475 8.29875C21.2775 8.32875 21.2888 8.37 21.315 8.40375H15.6V4.8ZM18.6 16.8C17.6063 16.8 16.8 15.9938 16.8 15C16.8 14.0063 17.6063 13.2 18.6 13.2C19.5938 13.2 20.4 14.0063 20.4 15C20.4 15.9938 19.5938 16.8 18.6 16.8ZM21.6 13.2H20.985C20.4375 12.4763 19.575 12 18.6 12C17.625 12 16.7625 12.4763 16.215 13.2H15.6V9.6H21.6V13.2ZM9.6 8.1V7.5C9.6 7.335 9.465 7.2 9.3 7.2H0.3C0.135 7.2 0 7.335 0 7.5V8.1C0 8.265 0.135 8.4 0.3 8.4H9.3C9.465 8.4 9.6 8.265 9.6 8.1Z" fill="currentColor"></path>
                </svg>
                {{ 'sections.cart.order_note' | t }}
              </button>
              <cart-dialog class="cart-dialog" id="cart-note">
                <div class="cart-dialog-wrapper relative">
                  <span class="cart-dialog-label block h6">{{ 'sections.cart.order_note' | t }}</span>
                  <a href="#" aria-label="Close" class="drawer-close cart--close" data-dialog-close>
                    <close-btn>
                      <svg
                        class="icon"
                        viewBox="0 0 20 20"
                        stroke="currentColor"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15L15 5M5 5L15 15"></path>
                      </svg>
                    </close-btn>
                  </a>
                  <div class="cart-dialog-inner">
                    <cart-note-content>
                      <div class="form-control">
                        <label for="DrawerOrderNote" class="hidden">{{- 'sections.cart.note_heading' | t -}}</label>
                        <textarea
                          class="input"
                          name="note"
                          rows="5"
                          id="DrawerOrderNote"
                          placeholder="{{ 'sections.cart.note' | t }}"
                          data-cart-note
                        >{{ cart.note }}</textarea>
                      </div>
                      <div class="form-control">
                        <button
                          type="button"
                          class="button button-sm {{ settings.button_font }}-font"
                          data-dialog-close
                        >
                          {{ 'sections.cart.save_note' | t }}
                        </button>
                      </div>
                    </cart-note-content>
                  </div>
                </div>
              </cart-dialog>
            {% endif %}
          </div>
        {% endif %}
        <div class="discount-with-total">
          {%- for discount in cart.cart_level_discount_applications -%}
            <div class="discount-amout bold text-sm">
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M5.33607 0.615767L4.74413 1.48503C4.6228 1.66313 4.40743 1.7524 4.19553 1.7121L3.16203 1.51623C2.70443 1.42913 2.2334 1.5743 1.90363 1.90363C1.5743 2.2334 1.42913 2.70443 1.51623 3.16203L1.7121 4.19553C1.7524 4.40743 1.66313 4.6228 1.48503 4.74413L0.615767 5.33607C0.230533 5.59823 0 6.03417 0 6.5C0 6.96583 0.230533 7.40177 0.615767 7.66393L1.48503 8.25587C1.66313 8.3772 1.7524 8.59257 1.7121 8.80447L1.51623 9.83797C1.42913 10.2956 1.5743 10.7666 1.90363 11.0964C2.2334 11.4257 2.70443 11.5709 3.16203 11.4838L4.19553 11.2879C4.40743 11.2476 4.6228 11.3369 4.74413 11.515L5.33607 12.3842C5.59823 12.7695 6.03417 13 6.5 13C6.96583 13 7.40177 12.7695 7.66393 12.3842L8.25587 11.515C8.3772 11.3369 8.59257 11.2476 8.80447 11.2879L9.83797 11.4838C10.2956 11.5709 10.7666 11.4257 11.0964 11.0964C11.4257 10.7666 11.5709 10.2956 11.4838 9.83797L11.2879 8.80447C11.2476 8.59257 11.3369 8.3772 11.515 8.25587L12.3842 7.66393C12.7695 7.40177 13 6.96583 13 6.5C13 6.03417 12.7695 5.59823 12.3842 5.33607L11.515 4.74413C11.3369 4.6228 11.2476 4.40743 11.2879 4.19553L11.4838 3.16203C11.5709 2.70443 11.4257 2.2334 11.0964 1.90363C10.7666 1.5743 10.2956 1.42913 9.83797 1.51623L8.80447 1.7121C8.59257 1.7524 8.3772 1.66313 8.25587 1.48503L7.66393 0.615767C7.40177 0.230533 6.96583 0 6.5 0C6.03417 0 5.59823 0.230533 5.33607 0.615767ZM8.23333 6.93333C7.51573 6.93333 6.93333 7.51573 6.93333 8.23333C6.93333 8.95093 7.51573 9.53333 8.23333 9.53333C8.95093 9.53333 9.53333 8.95093 9.53333 8.23333C9.53333 7.51573 8.95093 6.93333 8.23333 6.93333ZM8.3603 4.02697L4.02697 8.3603C3.85797 8.5293 3.85797 8.80403 4.02697 8.97303C4.19597 9.14203 4.4707 9.14203 4.6397 8.97303L8.97303 4.6397C9.14203 4.4707 9.14203 4.19597 8.97303 4.02697C8.80403 3.85797 8.5293 3.85797 8.3603 4.02697ZM8.23333 7.8C8.47253 7.8 8.66667 7.99413 8.66667 8.23333C8.66667 8.47253 8.47253 8.66667 8.23333 8.66667C7.99413 8.66667 7.8 8.47253 7.8 8.23333C7.8 7.99413 7.99413 7.8 8.23333 7.8ZM4.76667 3.46667C4.04907 3.46667 3.46667 4.04907 3.46667 4.76667C3.46667 5.48427 4.04907 6.06667 4.76667 6.06667C5.48427 6.06667 6.06667 5.48427 6.06667 4.76667C6.06667 4.04907 5.48427 3.46667 4.76667 3.46667ZM4.76667 4.33333C5.00587 4.33333 5.2 4.52747 5.2 4.76667C5.2 5.00587 5.00587 5.2 4.76667 5.2C4.52747 5.2 4.33333 5.00587 4.33333 4.76667C4.33333 4.52747 4.52747 4.33333 4.76667 4.33333Z" fill="currentColor"></path>
              </svg>
              {{ discount.title }} (-{{ discount.total_allocated_amount | money }})
            </div>
          {% endfor %}
          <div class="total-amount">
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <div class="flex justify-content-between">
                <span class="text-sm">{{ 'sections.cart.subtotal' | t }}</span>
                <span class="price text-base">{{ cart.original_total_price | money }}</span>
              </div>
            {% endif %}
            <div class="flex justify-content-between">
              <span class="text-sm">{{ 'sections.cart.total' | t }}</span>
              <span class="price text-base">{{ cart.total_price | money_with_currency }}</span>
            </div>
          </div>
        </div>
        <div id="cart-drawer-errors"></div>
        <div class="action-wrapper flex" data-action-cart-checkout-buttons>
          <a href="{{ routes.cart_url }}" class="button button-md button-secondary">
            <span class="button-text">{{ 'general.cart.view_empty_cart' | t }}</span>
          </a>
          <button type="submit" name="checkout" id="checkoutCart" form="cart" class="button button-md">
            <span class="button-text">{{ 'sections.cart.checkout' | t }}</span>
          </button>
        </div>
        <div class="flex align-items-center justify-content-between wrap text-xs">
          <shipping-tax>
            {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
              {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
            {%- elsif cart.taxes_included -%}
              {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
            {%- elsif shop.shipping_policy.body != blank -%}
              {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
            {%- else -%}
              {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
            {%- endif -%}
          </shipping-tax>
          <a href="{{ routes.all_products_collection_url }}" class="underline continue-shopping">
            {{ 'general.continue_shopping' | t }}
          </a>
        </div>
      </modal-dialog-foot>
    {% endif %}
  </div>
</cart-drawer>
